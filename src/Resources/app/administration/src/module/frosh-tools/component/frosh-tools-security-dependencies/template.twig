<div class="frosh-security-dependencies">
    <ft-panel :title="$t('frosh-tools.tabs.composerAudit.explainer.title')">
        <div class="frosh-security-dependencies__explainer">
            <div class="frosh-security-dependencies__point">
                <span
                    class="frosh-security-dependencies__point-icon frosh-security-dependencies__point-icon--accent"
                >
                    <ft-icon
                        name="file"
                        :size="18"
                    />
                </span>
                <div class="frosh-security-dependencies__point-body">
                    <h4 class="frosh-security-dependencies__point-title">
                        {{ $t('frosh-tools.tabs.composerAudit.explainer.whatTitle') }}
                    </h4>
                    <p class="frosh-security-dependencies__point-text">
                        {{ $t('frosh-tools.tabs.composerAudit.explainer.what') }}
                    </p>
                </div>
            </div>
            <div class="frosh-security-dependencies__point">
                <span
                    class="frosh-security-dependencies__point-icon frosh-security-dependencies__point-icon--warning"
                >
                    <ft-icon
                        name="alert"
                        :size="18"
                    />
                </span>
                <div class="frosh-security-dependencies__point-body">
                    <h4 class="frosh-security-dependencies__point-title">
                        {{ $t('frosh-tools.tabs.composerAudit.explainer.whyTitle') }}
                    </h4>
                    <p class="frosh-security-dependencies__point-text">
                        {{ $t('frosh-tools.tabs.composerAudit.explainer.why') }}
                    </p>
                </div>
            </div>
            <div class="frosh-security-dependencies__callout">
                <span
                    class="frosh-security-dependencies__point-icon frosh-security-dependencies__point-icon--info"
                >
                    <ft-icon
                        name="info"
                        :size="18"
                    />
                </span>
                <div class="frosh-security-dependencies__point-body">
                    <h4 class="frosh-security-dependencies__point-title">
                        {{ $t('frosh-tools.tabs.composerAudit.explainer.whoTitle') }}
                    </h4>
                    <p class="frosh-security-dependencies__point-text">
                        {{ $t('frosh-tools.tabs.composerAudit.explainer.who') }}
                    </p>
                </div>
            </div>
        </div>
    </ft-panel>
    <ft-panel
        v-if="hasAdvisories"
        :title="$t('frosh-tools.tabs.composerAudit.howto.title')"
    >
        <p class="frosh-security-dependencies__howto-warning">
                                                    <ft-icon name="alert"/>
                                                    <span>
            {{ $t('frosh-tools.tabs.composerAudit.howto.backup') }}
        </span>
        </p>
        <ol class="frosh-security-dependencies__howto">
            <li class="frosh-security-dependencies__howto-step">
                <div class="frosh-security-dependencies__howto-text">
                    {{ $t('frosh-tools.tabs.composerAudit.howto.step1') }}
                </div>
                <div class="frosh-security-dependencies__cmd">
                    <code class="ft-mono">{{ updateCommand }}</code>
                    <button
                        type="button"
                        class="ft-btn ft-btn--ghost frosh-security-dependencies__cmd-copy"
                        :title="$t('frosh-tools.tabs.composerAudit.howto.copy')"
                        @click="copyCommand(updateCommand)"
                    >
                        <ft-icon
                            :name="copiedCommand === updateCommand ? 'check' : 'copy'"
                        />
                    </button>
                </div>
            </li>
            <li class="frosh-security-dependencies__howto-step">
                <div class="frosh-security-dependencies__howto-text">
                    {{ $t('frosh-tools.tabs.composerAudit.howto.step2') }}
                </div>
            </li>
            <li class="frosh-security-dependencies__howto-step">
                <div class="frosh-security-dependencies__howto-text">
                    {{ $t('frosh-tools.tabs.composerAudit.howto.step3') }}
                </div>
                <div class="frosh-security-dependencies__cmd">
                    <code class="ft-mono">composer audit</code>
                    <button
                        type="button"
                        class="ft-btn ft-btn--ghost frosh-security-dependencies__cmd-copy"
                        :title="$t('frosh-tools.tabs.composerAudit.howto.copy')"
                        @click="copyCommand('composer audit')"
                    >
                        <ft-icon
                            :name="copiedCommand === 'composer audit' ? 'check' : 'copy'"
                        />
                    </button>
                </div>
            </li>
            <li class="frosh-security-dependencies__howto-step">
                <div class="frosh-security-dependencies__howto-text">
                    {{ $t('frosh-tools.tabs.composerAudit.howto.step4') }}
                </div>
            </li>
        </ol>
        <p class="frosh-security-dependencies__howto-note">
                                                    <ft-icon name="info"/>
                                                    <span>
            {{ $t('frosh-tools.tabs.composerAudit.howto.note') }}
        </span>
        </p>
    </ft-panel>
    <ft-panel
        :title="$t('frosh-tools.tabs.composerAudit.title')"
        :count="result.advisories ? result.advisories.length : null"
    >
        <template #actions>
            <span
                v-if="cachedAtLabel()"
                class="frosh-security-dependencies__cached"
            >
                {{ $t('frosh-tools.tabs.composerAudit.cachedAt', { at: cachedAtLabel() }) }}
            </span>
            <ft-refresh-button
                :loading="isLoading"
                label="Refresh"
                @click="refresh"
            />
        </template>
        <ft-hero-state
            v-if="hasError"
            variant="danger"
            icon="alert"
            :title="$t('frosh-tools.tabs.composerAudit.checkFailed')"
            :body="result.error"
        />
        <ft-hero-state
            v-else-if="!hasAdvisories && !isLoading"
            variant="success"
            icon="check"
            :title="$t('frosh-tools.tabs.composerAudit.allOk')"
            :body="$t('frosh-tools.tabs.composerAudit.scannedPackages', { count: result.packages })"
        />
        <ft-hero-state
            v-else-if="hasAdvisories"
            variant="danger"
            icon="alert"
            :title="$t('frosh-tools.tabs.composerAudit.vulnerableTitle', { count: result.advisories.length })"
            :body="$t('frosh-tools.tabs.composerAudit.vulnerableBody', { vulnerable: result.vulnerable, total: result.packages })"
        />
        <div
            v-if="hasAdvisories"
            class="frosh-security-dependencies__list"
        >
            <div
                v-for="group in groupedAdvisories"
                :key="group.packageName"
                class="frosh-security-dependencies__group"
            >
                <div class="frosh-security-dependencies__group-head">
                    <div class="frosh-security-dependencies__group-pkg">
                        <ft-pill
                            variant="accent"
                            bare
                        >package</ft-pill>
                        <span
                            class="ft-mono frosh-security-dependencies__group-name"
                        >{{ group.packageName }}</span>
                        <span
                            v-if="group.installedVersion"
                            class="frosh-security-dependencies__group-version ft-mono"
                        >{{ group.installedVersion }}</span>
                        <span
                            v-if="group.sources && group.sources.length"
                            class="frosh-security-dependencies__group-sources"
                        >
                            <ft-pill
                                v-for="src in group.sources"
                                :key="src"
                                :variant="src === 'project' ? 'muted' : 'warning'"
                                bare
                            >{{ sourceLabel(src) }}</ft-pill>
                        </span>
                    </div>
                    <span class="ft-panel__count">{{ group.advisories.length }}</span>
                </div>
                <ul class="frosh-security-dependencies__advisories">
                    <li
                        v-for="adv in group.advisories"
                        :key="adv.advisoryId || `${group.packageName}-${adv.title}`"
                        class="frosh-security-dependencies__advisory"
                    >
                        <div class="frosh-security-dependencies__advisory-head">
                            <ft-pill :variant="severityVariant(adv.severity)">
                                {{ severityLabel(adv.severity) }}
                            </ft-pill>
                            <span
                                v-if="adv.cve"
                                class="ft-mono frosh-security-dependencies__cve"
                            >{{ adv.cve }}</span>
                            <span
                                v-else-if="adv.advisoryId"
                                class="ft-mono frosh-security-dependencies__cve"
                            >{{ adv.advisoryId }}</span>
                            <a
                                v-if="adv.link"
                                class="ft-link"
                                @click="openUrl(adv.link)"
                            >
                                <ft-icon name="external-link"/>
                            </a>
                        </div>
                        <div class="frosh-security-dependencies__advisory-title">{{ adv.title }}</div>
                        <div class="frosh-security-dependencies__advisory-meta">
                            <span v-if="adv.affectedVersions">
                                <strong>
                                    {{ $t('frosh-tools.tabs.composerAudit.affected') }}
                                    :
                                </strong>
                                <span class="ft-mono">{{ adv.affectedVersions }}</span>
                            </span>
                            <span v-if="adv.reportedAt">
                                <strong>
                                    {{ $t('frosh-tools.tabs.composerAudit.reportedAt') }}
                                    :
                                </strong>
                                {{ adv.reportedAt }}
                            </span>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </ft-panel>
</div>