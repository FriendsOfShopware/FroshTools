<div class="frosh-security-files">
    <ft-panel
        title="Core"
        :count="items.files ? items.files.length : null"
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                @click="refresh"
            />
        </template>
        <ft-hero-state
            v-if="items.error"
            variant="danger"
            icon="alert"
            title="Check failed"
            :body="items.error"
        />
        <ft-hero-state
            v-else-if="items.ok"
            variant="success"
            icon="check"
            :title="$t('frosh-tools.tabs.files.allFilesOk')"
            body="Every shipped file matches its expected checksum."
        />
        <ft-hero-state
            v-else-if="items.files && items.files.length"
            variant="warning"
            icon="alert"
            :title="$t('frosh-tools.tabs.files.notOk')"
            :body="`${items.files.length} file${items.files.length === 1 ? '' : 's'} differ from the original.`"
        />
        <div
            v-if="items.files && items.files.length"
            class="ft-table-wrap frosh-security-files__table"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <ft-th-sort sort-key="name">{{ $t('frosh-tools.name') }}</ft-th-sort>
                        <ft-th-sort sort-key="expected">{{ $t('frosh-tools.status') }}</ft-th-sort>
                        <th class="ft-table__actions">
                            {{ $t('frosh-tools.actions') }}
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="item in sortRows(items.files)"
                        :key="item.name"
                    >
                        <td>
                            <a
                                class="ft-link ft-mono"
                                @click="diff(item)"
                                :title="$t('frosh-tools.tabs.files.restore.diff')"
                            >{{ item.name }}</a>
                        </td>
                        <td>
                            <ft-pill :variant="item.expected ? 'muted' : 'warning'">
                                {{ item.expected ? $t('frosh-tools.tabs.files.expectedProject') : $t('frosh-tools.tabs.files.expectedAll') }}
                            </ft-pill>
                        </td>
                        <td class="ft-table__actions">
                            <button
                                class="ft-btn ft-btn--ghost"
                                @click="openUrl(item.shopwareUrl)"
                            >
                                <ft-icon name="external-link"/>
                            </button>
                            <button
                                class="ft-btn"
                                @click="diff(item)"
                            >
                                {{ $t('frosh-tools.tabs.files.restore.diff') }}
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
    <ft-modal
        v-if="showModal"
        variant="large"
        @close="closeModal"
        :title="diffData.file.name"
    >
        <pre
            class="ft-diff"
            v-html="diffData.html"
        ></pre>
        <template #footer>
            <button
                class="ft-btn"
                @click="closeModal"
            >
                {{ $t('global.default.close') }}
            </button>
            <button
                class="ft-btn ft-btn--danger"
                @click="restoreFile(diffData.file.name)"
                :disabled="diffData.file.expected"
            >
                <ft-icon name="alert"/>
                {{ $t('frosh-tools.tabs.files.restore.restoreFile') }}
            </button>
        </template>
    </ft-modal>
    <ft-panel :title="$t('frosh-tools.tabs.extensionFiles.title')">
        <ft-hero-state
            v-if="extensionItems.success"
            variant="success"
            icon="check"
            :title="$t('frosh-tools.tabs.extensionFiles.allFilesOk')"
        />
        <ft-hero-state
            v-else
            variant="warning"
            icon="alert"
            :title="$t('frosh-tools.tabs.extensionFiles.notOk')"
        />
        <div
            v-for="(extensionResult, extensionName) in extensionItems.extensionResults"
            :key="extensionName"
            class="frosh-security-files__ext"
        >
            <div class="frosh-security-files__ext-head">
                <ft-pill
                    variant="accent"
                    bare
                >extension</ft-pill>
                <h3 class="frosh-security-files__ext-name">{{ extensionName }}</h3>
            </div>
            <ft-hero-state
                v-if="extensionResult.wrongExtensionVersion"
                variant="warning"
                icon="alert"
                :title="$t('frosh-tools.tabs.extensionFiles.wrongExtensionVersion')"
            />
            <ft-hero-state
                v-else-if="extensionResult.checkFailed"
                variant="danger"
                icon="alert"
                :title="$t('frosh-tools.tabs.extensionFiles.checkFailed')"
            />
            <div
                v-else
                class="frosh-security-files__ext-grid"
            >
                <div
                    v-if="extensionResult.newFiles.length > 0"
                    class="frosh-security-files__ext-group"
                >
                    <div class="frosh-security-files__ext-label">
                        <ft-pill
                            variant="info"
                            bare
                        >new</ft-pill>
                        {{ $t('frosh-tools.tabs.extensionFiles.newFiles') }}
                        <span class="ft-panel__count">
                            {{ extensionResult.newFiles.length }}
                        </span>
                    </div>
                    <ul class="frosh-security-files__ext-list">
                        <li
                            v-for="f in extensionResult.newFiles"
                            :key="`n-${f}`"
                            class="ft-mono"
                        >{{ f }}</li>
                    </ul>
                </div>
                <div
                    v-if="extensionResult.changedFiles.length > 0"
                    class="frosh-security-files__ext-group"
                >
                    <div class="frosh-security-files__ext-label">
                        <ft-pill
                            variant="warning"
                            bare
                        >changed</ft-pill>
                        {{ $t('frosh-tools.tabs.extensionFiles.changedFiles') }}
                        <span class="ft-panel__count">
                            {{ extensionResult.changedFiles.length }}
                        </span>
                    </div>
                    <ul class="frosh-security-files__ext-list">
                        <li
                            v-for="f in extensionResult.changedFiles"
                            :key="`c-${f}`"
                            class="ft-mono"
                        >{{ f }}</li>
                    </ul>
                </div>
                <div
                    v-if="extensionResult.missingFiles.length > 0"
                    class="frosh-security-files__ext-group"
                >
                    <div class="frosh-security-files__ext-label">
                        <ft-pill
                            variant="danger"
                            bare
                        >missing</ft-pill>
                        {{ $t('frosh-tools.tabs.extensionFiles.missingFiles') }}
                        <span class="ft-panel__count">
                            {{ extensionResult.missingFiles.length }}
                        </span>
                    </div>
                    <ul class="frosh-security-files__ext-list">
                        <li
                            v-for="f in extensionResult.missingFiles"
                            :key="`m-${f}`"
                            class="ft-mono"
                        >{{ f }}</li>
                    </ul>
                </div>
            </div>
        </div>
    </ft-panel>
</div>