<div class="ft frosh-tab-cache">
    <ft-page-head
        :title="$t('frosh-tools.tabs.cache.title')"
        :subtitle="$t('frosh-tools.tabs.cache.subtitle')"
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                @click="createdComponent"
            />
            <button
                class="ft-btn"
                @click="compileTheme"
                :disabled="isLoading"
            >
                <ft-icon name="paint"/>
                <span>
                    {{ $t('frosh-tools.compileTheme') }}
                </span>
            </button>
            <button
                class="ft-btn ft-btn--primary"
                @click="clearOPcache"
                :disabled="isLoading"
            >
                <ft-icon name="bolt"/>
                <span>
                    {{ $t('frosh-tools.clearOpCache') }}
                </span>
            </button>
        </template>
    </ft-page-head>
    <ft-hero-state
        v-if="loadError"
        variant="danger"
        icon="alert"
        :title="$t('frosh-tools.loadError.title')"
        :body="loadError"
    >
        <template #actions>
            <ft-button
                icon="refresh"
                @click="createdComponent"
            >
                {{ $t('frosh-tools.loadError.retry') }}
            </ft-button>
        </template>
    </ft-hero-state>
    <ft-panel
        v-else
        :title="$t('frosh-tools.tabs.cache.pools')"
        :count="visibleCacheFolders.length"
        flush
    >
        <ft-empty
            v-if="isLoading && !cacheFolders.length"
            loading
        />
        <ft-empty
            v-else-if="!cacheFolders.length"
            :title="$t('frosh-tools.tabs.cache.noPools')"
        />
        <ft-empty
            v-else-if="!visibleCacheFolders.length"
            icon="search"
            :title="$t('frosh-tools.search.noResults', { term: searchTerm })"
        />
        <div
            v-else
            class="ft-table-wrap"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <ft-th-sort sort-key="name">{{ $t('frosh-tools.name') }}</ft-th-sort>
                        <ft-th-sort
                            sort-key="size"
                            class="ft-table__num"
                        >{{ $t('frosh-tools.used') }}</ft-th-sort>
                        <ft-th-sort
                            sort-key="freeSpace"
                            class="ft-table__num"
                        >{{ $t('frosh-tools.free') }}</ft-th-sort>
                        <th class="ft-table__actions">
                            {{ $t('frosh-tools.actions') }}
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="item in sortRows(visibleCacheFolders)"
                        :key="item.name"
                    >
                        <td class="ft-table__name">
                            <div class="frosh-tab-cache__name-row">
                                <ft-pill
                                    v-if="item.active"
                                    variant="success"
                                >{{ $t('frosh-tools.active') }}</ft-pill>
                                <ft-pill
                                    v-if="item.type"
                                    variant="muted"
                                    bare
                                >{{ item.type }}</ft-pill>
                                <span>{{ item.name }}</span>
                            </div>
                        </td>
                        <td class="ft-table__num">
                            <template v-if="item.size < 0">
                                {{ $t('frosh-tools.unknown') }}
                            </template>

                            <template v-else>{{ formatSize(item.size) }}</template>
                        </td>
                        <td class="ft-table__num">
                            <template v-if="item.freeSpace < 0">
                                {{ $t('frosh-tools.unknown') }}
                            </template>

                            <template v-else>
                                {{ formatSize(item.freeSpace) }}
                            </template>
                        </td>
                        <td class="ft-table__actions">
                            <button
                                class="ft-btn ft-btn--danger"
                                @click="clearCache(item)"
                            >
                                <ft-icon name="trash"/>
                                {{ $t('frosh-tools.clear') }}
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
</div>