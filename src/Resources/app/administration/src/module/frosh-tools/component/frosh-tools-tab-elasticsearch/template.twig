<div class="ft frosh-tab-es">
    <ft-page-head
        :title="$t('frosh-tools.tabs.elasticsearch.title')"
        subtitle="Cluster status, indices and a low-level query console."
    >
        <template
            #actions
            v-if="!isLoading && isActive"
        >
            <ft-refresh-button
                :loading="isLoading"
                label="Refresh"
                @click="createdComponent"
            />
        </template>
    </ft-page-head>
    <ft-empty
        v-if="isLoading"
        loading
    />
    <template v-else-if="!isActive">
        <ft-hero-state
            variant="danger"
            icon="alert"
            title="Elasticsearch is not enabled"
            :body="$t('frosh-tools.tabs.elasticsearch.disabled')"
        />
    </template>

    <template v-else>
        <ft-panel
            :title="$t('frosh-tools.tabs.elasticsearch.indices')"
            :count="indices ? indices.length : 0"
            flush
        >
            <template #actions>
                <button
                    class="ft-btn ft-btn--primary"
                    @click="reindex"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.reindex') }}
                </button>
                <button
                    class="ft-btn"
                    @click="switchAlias"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.switchAlias') }}
                </button>
                <button
                    class="ft-btn"
                    @click="showUnusedIndices"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.showUnused') }}
                </button>
                <button
                    class="ft-btn"
                    @click="cleanup"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.cleanup') }}
                </button>
                <button
                    class="ft-btn ft-btn--danger"
                    @click="cleanupOrphaned"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.cleanupOrphaned') }}
                </button>
                <button
                    class="ft-btn ft-btn--danger"
                    @click="flushAll"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.flushAll') }}
                </button>
                <button
                    class="ft-btn ft-btn--danger"
                    @click="resetElasticsearch"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.reset') }}
                </button>
            </template>
            <ft-empty
                v-if="!indices.length"
                title="No indices found"
            />
            <div
                v-else
                class="ft-table-wrap"
            >
                <table class="ft-table">
                    <thead>
                        <tr>
                            <ft-th-sort sort-key="name">{{ $t('frosh-tools.name') }}</ft-th-sort>
                            <ft-th-sort
                                sort-key="indexSize"
                                class="ft-table__num"
                            >{{ $t('frosh-tools.size') }}</ft-th-sort>
                            <ft-th-sort
                                sort-key="docs"
                                class="ft-table__num"
                            >{{ $t('frosh-tools.docs') }}</ft-th-sort>
                            <th class="ft-table__actions">
                                {{ $t('frosh-tools.actions') }}
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr
                            v-for="item in sortRows(indices)"
                            :key="item.name"
                        >
                            <td class="ft-table__name">
                                <div class="frosh-tab-es__name">
                                    <ft-pill
                                        v-if="item.aliases.length"
                                        variant="success"
                                    >{{ $t('frosh-tools.active') }}</ft-pill>
                                    <span class="ft-mono">{{ item.name }}</span>
                                </div>
                            </td>
                            <td class="ft-table__num">
                                {{ formatSize(item.indexSize) }}
                            </td>
                            <td class="ft-table__num">
                                {{ Number(item.docs).toLocaleString() }}
                            </td>
                            <td class="ft-table__actions">
                                <button
                                    class="ft-btn ft-btn--danger"
                                    @click="deleteIndex(item.name)"
                                >
                                    <ft-icon name="trash"/>
                                    {{ $t('frosh-tools.delete') }}
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </ft-panel>
        <ft-panel :title="$t('frosh-tools.tabs.elasticsearch.console.title')">
            <template #actions>
                <button
                    class="ft-btn ft-btn--primary"
                    @click="onConsoleEnter"
                >
                    <ft-icon name="send"/>
                    {{ $t('frosh-tools.tabs.elasticsearch.console.send') }}
                </button>
            </template>
            <div class="frosh-tab-es__editor">
                <sw-code-editor
                    completionMode="text"
                    mode="twig"
                    :softWraps="true"
                    :setFocus="false"
                    :disabled="false"
                    :sanitizeInput="false"
                    v-model:value="consoleInput"
                ></sw-code-editor>
            </div>
            <div class="frosh-tab-es__output-label">
                {{ $t('frosh-tools.tabs.elasticsearch.console.output') }}
            </div>
            <pre class="ft-diff frosh-tab-es__output">{{ consoleOutput }}</pre>
        </ft-panel>
    </template>
</div>
