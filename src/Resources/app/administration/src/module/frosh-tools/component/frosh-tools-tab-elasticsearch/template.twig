<div class="ft frosh-tab-es">
    <ft-page-head
        :title="engineName"
        :subtitle="$t('frosh-tools.tabs.elasticsearch.subtitle')"
    >
        <template
            #actions
            v-if="!isLoading && isActive"
        >
            <ft-refresh-button
                :loading="isLoading"
                @click="createdComponent"
            />
        </template>
    </ft-page-head>
    <ft-empty
        v-if="isLoading"
        loading
    />
    <template v-else-if="!isActive">
        <ft-hero-state
            variant="danger"
            icon="alert"
            :title="$t('frosh-tools.tabs.elasticsearch.disabledTitle', { engine: engineName })"
            :body="$t('frosh-tools.tabs.elasticsearch.disabled')"
        />
    </template>

    <template v-else>
        <div
            v-if="engineVersion || clusterHealth || nodeCount !== null"
            class="frosh-tab-es__status-bar"
        >
            <div
                v-if="engineVersion"
                class="frosh-tab-es__status-item"
            >
                <span class="frosh-tab-es__status-label">
                    {{ $t('frosh-tools.tabs.elasticsearch.version') }}
                </span>
                <ft-pill variant="info">{{ engineVersion }}</ft-pill>
            </div>
            <div
                v-if="nodeCount !== null"
                class="frosh-tab-es__status-item"
            >
                <span class="frosh-tab-es__status-label">
                    {{ $t('frosh-tools.tabs.elasticsearch.nodes') }}
                </span>
                <ft-pill variant="info">{{ nodeCount }}</ft-pill>
            </div>
            <div
                v-if="clusterHealth"
                class="frosh-tab-es__status-item"
            >
                <span class="frosh-tab-es__status-label">
                    {{ $t('frosh-tools.tabs.elasticsearch.status') }}
                </span>
                <ft-pill :variant="healthVariant">{{ clusterHealth }}</ft-pill>
            </div>
        </div>
        <ft-panel
            :title="$t('frosh-tools.tabs.elasticsearch.indices')"
            :count="indices ? indices.length : 0"
            flush
        >
            <template #actions>
                <button
                    class="ft-btn ft-btn--primary"
                    @click="reindex"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.reindex') }}
                </button>
                <button
                    class="ft-btn"
                    @click="switchAlias"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.switchAlias') }}
                </button>
                <button
                    class="ft-btn"
                    v-tooltip="{
                        showDelay: 300,
                        message: $t('frosh-tools.tabs.elasticsearch.tooltip.unused')
                    }"
                    @click="showUnusedIndices"
                >
                    <ft-pill
                        bare
                        variant="info"
                        class="frosh-tab-es__action-pill"
                    >
                        {{ $t('frosh-tools.tabs.elasticsearch.badge.shopware') }}
                    </ft-pill>
                    {{ $t('frosh-tools.tabs.elasticsearch.action.showUnused') }}
                </button>
                <button
                    class="ft-btn"
                    v-tooltip="{
                        showDelay: 300,
                        message: $t('frosh-tools.tabs.elasticsearch.tooltip.cleanup')
                    }"
                    @click="cleanup"
                >
                    <ft-pill
                        bare
                        variant="info"
                        class="frosh-tab-es__action-pill"
                    >
                        {{ $t('frosh-tools.tabs.elasticsearch.badge.shopware') }}
                    </ft-pill>
                    {{ $t('frosh-tools.tabs.elasticsearch.action.cleanup') }}
                </button>
                <button
                    class="ft-btn ft-btn--danger"
                    v-tooltip="{
                        showDelay: 300,
                        message: $t('frosh-tools.tabs.elasticsearch.tooltip.orphaned')
                    }"
                    :disabled="isLoadingOrphanedPreview || isCleaningOrphaned"
                    @click="openOrphanedCleanupModal"
                >
                    <span
                        v-if="isLoadingOrphanedPreview"
                        class="ft-spinner"
                    ></span>
                    <ft-pill
                        v-else
                        bare
                        variant="warning"
                        class="frosh-tab-es__action-pill"
                    >
                        {{ $t('frosh-tools.tabs.elasticsearch.badge.heuristic') }}
                    </ft-pill>
                    {{ $t('frosh-tools.tabs.elasticsearch.action.cleanupOrphaned') }}
                </button>
                <button
                    class="ft-btn ft-btn--danger"
                    @click="askFlushAll"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.flushAll') }}
                </button>
                <button
                    class="ft-btn ft-btn--danger"
                    @click="askReset"
                >
                    {{ $t('frosh-tools.tabs.elasticsearch.action.reset') }}
                </button>
            </template>
            <ft-empty
                v-if="!indices.length"
                :title="$t('frosh-tools.tabs.elasticsearch.noIndices')"
            />
            <div
                v-else
                class="ft-table-wrap"
            >
                <table class="ft-table">
                    <thead>
                        <tr>
                            <ft-th-sort sort-key="name">{{ $t('frosh-tools.name') }}</ft-th-sort>
                            <ft-th-sort
                                sort-key="indexSize"
                                class="ft-table__num"
                            >{{ $t('frosh-tools.size') }}</ft-th-sort>
                            <ft-th-sort
                                sort-key="docs"
                                class="ft-table__num"
                            >{{ $t('frosh-tools.docs') }}</ft-th-sort>
                            <th class="ft-table__actions">
                                {{ $t('frosh-tools.actions') }}
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr
                            v-for="item in sortRows(indices)"
                            :key="item.name"
                        >
                            <td class="ft-table__name">
                                <div class="frosh-tab-es__name">
                                    <ft-pill
                                        v-if="item.aliases.length"
                                        variant="success"
                                    >{{ $t('frosh-tools.active') }}</ft-pill>
                                    <span class="ft-mono">{{ item.name }}</span>
                                </div>
                            </td>
                            <td class="ft-table__num">
                                {{ formatSize(item.indexSize) }}
                            </td>
                            <td class="ft-table__num">
                                {{ Number(item.docs).toLocaleString() }}
                            </td>
                            <td class="ft-table__actions">
                                <button
                                    class="ft-btn ft-btn--danger"
                                    @click="askDeleteIndex(item.name)"
                                >
                                    <ft-icon name="trash"/>
                                    {{ $t('frosh-tools.delete') }}
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </ft-panel>
        <ft-panel
            :title="$t('frosh-tools.tabs.elasticsearch.console.title', { engine: engineName })"
        >
            <template #actions>
                <button
                    class="ft-btn ft-btn--primary"
                    @click="onConsoleEnter"
                >
                    <ft-icon name="send"/>
                    {{ $t('frosh-tools.tabs.elasticsearch.console.send') }}
                </button>
            </template>
            <div class="frosh-tab-es__editor">
                <sw-code-editor
                    ref="consoleEditor"
                    completion-mode="text"
                    mode="twig"
                    :soft-wraps="true"
                    :set-focus="false"
                    :disabled="false"
                    :sanitize-input="false"
                    v-model:value="consoleInput"
                    @mounted="resizeCodeEditor('consoleEditor')"
                ></sw-code-editor>
            </div>
            <div class="frosh-tab-es__output-label">
                {{ $t('frosh-tools.tabs.elasticsearch.console.output') }}
            </div>
            <pre class="ft-diff frosh-tab-es__output">{{ consoleOutput }}</pre>
        </ft-panel>
    </template>
    <ft-modal
        v-if="confirmAction"
        :title="$t(`frosh-tools.tabs.elasticsearch.confirm.${confirmAction.key}.title`, { name: confirmAction.indexName })"
        variant="small"
        :close-on-backdrop="!isConfirmingAction"
        @close="cancelConfirmAction"
    >
        {{ $t(`frosh-tools.tabs.elasticsearch.confirm.${confirmAction.key}.description`, { name: confirmAction.indexName }) }}
        <template #footer>
            <button
                class="ft-btn"
                :disabled="isConfirmingAction"
                @click="cancelConfirmAction"
            >
                {{ $t('global.default.cancel') }}
            </button>
            <button
                class="ft-btn ft-btn--danger"
                :disabled="isConfirmingAction"
                @click="runConfirmedAction"
            >
                <span
                    v-if="isConfirmingAction"
                    class="ft-spinner"
                ></span>
                <ft-icon
                    v-else
                    name="trash"
                />
                {{ $t(`frosh-tools.tabs.elasticsearch.confirm.${confirmAction.key}.confirm`) }}
            </button>
        </template>
    </ft-modal>
    <ft-modal
        v-if="showOrphanedCleanupModal"
        :title="$t('frosh-tools.tabs.elasticsearch.orphanedModal.title')"
        variant="large"
        @close="closeOrphanedCleanupModal()"
    >
        <div class="frosh-tab-es__cleanup-modal">
            <div class="frosh-tab-es__cleanup-summary">
                <ft-pill variant="warning">
                    {{ $t('frosh-tools.tabs.elasticsearch.badge.heuristic') }}
                </ft-pill>
                <span>
                    {{ $t('frosh-tools.tabs.elasticsearch.orphanedModal.summary', { count: orphanedCleanupIndices.length }) }}
                </span>
            </div>
            <p class="frosh-tab-es__cleanup-text">
                {{ $t('frosh-tools.tabs.elasticsearch.orphanedModal.description') }}
            </p>
            <ul class="frosh-tab-es__index-list">
                <li
                    v-for="index in orphanedCleanupIndices"
                    :key="index"
                    class="frosh-tab-es__index-list-item ft-mono"
                >
                    {{ index }}
                </li>
            </ul>
        </div>
        <template #footer>
            <button
                class="ft-btn"
                :disabled="isCleaningOrphaned"
                @click="closeOrphanedCleanupModal()"
            >
                {{ $t('global.default.cancel') }}
            </button>
            <button
                class="ft-btn ft-btn--danger"
                :disabled="isCleaningOrphaned"
                @click="confirmCleanupOrphaned"
            >
                <span
                    v-if="isCleaningOrphaned"
                    class="ft-spinner"
                ></span>
                <ft-icon
                    v-else
                    name="trash"
                />
                {{ $t('frosh-tools.tabs.elasticsearch.orphanedModal.delete') }}
            </button>
        </template>
    </ft-modal>
</div>