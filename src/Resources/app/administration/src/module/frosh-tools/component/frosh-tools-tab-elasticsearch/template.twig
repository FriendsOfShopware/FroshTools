<div class="ft frosh-tab-es">
    <div class="ft-page-head">
        <div>
            <h1 class="ft-page-head__title">{{ $t('frosh-tools.tabs.elasticsearch.title') }}</h1>
            <div class="ft-page-head__sub">Cluster status, indices and a low-level query console.</div>
        </div>
        <div class="ft-page-head__actions" v-if="!isLoading && isActive">
            <button class="ft-btn" @click="createdComponent" :disabled="isLoading">
                <ft-icon name="refresh" />
                <span>Refresh</span>
            </button>
        </div>
    </div>

    <div v-if="isLoading" class="ft-empty"><span class="ft-spinner"></span></div>

    <template v-else-if="!isActive">
        <div class="ft-hero-state ft-hero-state--danger">
            <div class="ft-hero-state__icon">
                <ft-icon name="alert" :size="22" />
            </div>
            <div>
                <div class="ft-hero-state__title">Elasticsearch is not enabled</div>
                <div class="ft-hero-state__body">{{ $t('frosh-tools.tabs.elasticsearch.disabled') }}</div>
            </div>
        </div>
    </template>

    <template v-else>
        <div class="ft-stat-grid">
            <div class="ft-stat" :class="statusStatClass">
                <div class="ft-stat__label">{{ $t('frosh-tools.tabs.elasticsearch.status') }}</div>
                <div class="ft-stat__value">{{ statusInfo.health.status }}</div>
            </div>
            <div class="ft-stat ft-stat--info">
                <div class="ft-stat__label">{{ $t('frosh-tools.tabs.elasticsearch.version') }}</div>
                <div class="ft-stat__value">{{ statusInfo.info.version.number }}</div>
            </div>
            <div class="ft-stat ft-stat--accent">
                <div class="ft-stat__label">{{ $t('frosh-tools.tabs.elasticsearch.nodes') }}</div>
                <div class="ft-stat__value">{{ statusInfo.health.number_of_nodes }}</div>
            </div>
            <div class="ft-stat">
                <div class="ft-stat__label">Indices</div>
                <div class="ft-stat__value">{{ indices ? indices.length : 0 }}</div>
            </div>
        </div>

        <section class="ft-panel">
            <div class="ft-panel__head">
                <h2 class="ft-panel__title">
                    {{ $t('frosh-tools.tabs.elasticsearch.indices') }}
                    <span class="ft-panel__count">{{ indices ? indices.length : 0 }}</span>
                </h2>
                <div class="ft-panel__actions">
                    <button class="ft-btn ft-btn--primary" @click="reindex">{{ $t('frosh-tools.tabs.elasticsearch.action.reindex') }}</button>
                    <button class="ft-btn" @click="switchAlias">{{ $t('frosh-tools.tabs.elasticsearch.action.switchAlias') }}</button>
                    <button class="ft-btn" @click="cleanup">{{ $t('frosh-tools.tabs.elasticsearch.action.cleanup') }}</button>
                    <button class="ft-btn ft-btn--danger" @click="flushAll">{{ $t('frosh-tools.tabs.elasticsearch.action.flushAll') }}</button>
                    <button class="ft-btn ft-btn--danger" @click="resetElasticsearch">{{ $t('frosh-tools.tabs.elasticsearch.action.reset') }}</button>
                </div>
            </div>
            <div class="ft-panel__body ft-panel__body--flush">
                <div v-if="!indices.length" class="ft-empty">
                    <div class="ft-empty__title">No indices found</div>
                </div>
                <div v-else class="ft-table-wrap">
                    <table class="ft-table">
                        <thead>
                            <tr>
                                <th>{{ $t('frosh-tools.name') }}</th>
                                <th class="ft-table__num">{{ $t('frosh-tools.size') }}</th>
                                <th class="ft-table__num">{{ $t('frosh-tools.docs') }}</th>
                                <th class="ft-table__actions">{{ $t('frosh-tools.actions') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr v-for="item in indices" :key="item.name">
                                <td class="ft-table__name">
                                    <div class="frosh-tab-es__name">
                                        <span class="ft-pill ft-pill--success" v-if="item.aliases.length">{{ $t('frosh-tools.active') }}</span>
                                        <span class="ft-mono">{{ item.name }}</span>
                                    </div>
                                </td>
                                <td class="ft-table__num">{{ formatSize(item.indexSize) }}</td>
                                <td class="ft-table__num">{{ Number(item.docs).toLocaleString() }}</td>
                                <td class="ft-table__actions">
                                    <button class="ft-btn ft-btn--danger" @click="deleteIndex(item.name)">
                                        <ft-icon name="trash" />
                                        {{ $t('frosh-tools.delete') }}
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="ft-panel">
            <div class="ft-panel__head">
                <h2 class="ft-panel__title">{{ $t('frosh-tools.tabs.elasticsearch.console.title') }}</h2>
                <div class="ft-panel__actions">
                    <button class="ft-btn ft-btn--primary" @click="onConsoleEnter">
                        <ft-icon name="send" />
                        {{ $t('frosh-tools.tabs.elasticsearch.console.send') }}
                    </button>
                </div>
            </div>
            <div class="ft-panel__body">
                <div class="frosh-tab-es__editor">
                    <sw-code-editor
                        completionMode="text"
                        mode="twig"
                        :softWraps="true"
                        :setFocus="false"
                        :disabled="false"
                        :sanitizeInput="false"
                        v-model:value="consoleInput"
                    ></sw-code-editor>
                </div>
                <div class="frosh-tab-es__output-label">{{ $t('frosh-tools.tabs.elasticsearch.console.output') }}</div>
                <pre class="ft-diff frosh-tab-es__output">{{ consoleOutput }}</pre>
            </div>
        </section>
    </template>
</div>
