<div class="ft frosh-tab-fastly">
    <ft-page-head
        :title="$t('frosh-tools.tabs.fastly.title')"
        subtitle="Fastly cache observability and purge controls."
    />
    <ft-panel :title="$t('frosh-tools.tabs.fastly.statsTitle')">
        <template #actions>
            <div class="frosh-tab-fastly__select">
                <sw-single-select
                    :placeholder="$t('frosh-tools.tabs.fastly.timeframeLabel')"
                    :options="timeframeOptions"
                    v-model:value="timeframe"
                    @update:value="loadStats"
                    :showSearch="false"
                    size="small"
                />
            </div>
        </template>
        <ft-empty
            v-if="!stats"
            icon="chart"
            :title="$t('frosh-tools.tabs.fastly.emptyStats')"
        />
        <dl
            v-else
            class="ft-kv frosh-tab-fastly__metrics"
        >
            <dt>
                {{ $t('frosh-tools.tabs.fastly.requests') }}
            </dt>
            <dd>
                {{ formatNumber(stats.requests) }}
            </dd>
            <dt>
                {{ $t('frosh-tools.tabs.fastly.hitRate') }}
            </dt>
            <dd>
                {{ formatNumber(stats.hit_ratio * 100) }}
                %
            </dd>
            <dt>
                {{ $t('frosh-tools.tabs.fastly.bandwidth') }}
            </dt>
            <dd>
                {{ formatSize(stats.bandwidth) }}
            </dd>
            <dt>
                {{ $t('frosh-tools.tabs.fastly.hits') }}
            </dt>
            <dd>{{ formatNumber(stats.hits) }}</dd>
        </dl>
    </ft-panel>
    <ft-panel title="Purge controls">
        <p class="frosh-tab-fastly__desc">
            {{ $t('frosh-tools.tabs.fastly.description') }}
        </p>
        <div class="frosh-tab-fastly__row">
            <div class="frosh-tab-fastly__row-grow">
                <sw-text-field
                    v-model="purgePath"
                    :placeholder="$t('frosh-tools.tabs.fastly.placeholderPath')"
                    :label="$t('frosh-tools.tabs.fastly.purgePathLabel')"
                />
            </div>
            <div class="frosh-tab-fastly__row-actions">
                <button
                    class="ft-btn"
                    :disabled="!purgePath || isLoading"
                    @click="onPurge"
                >
                    <ft-icon name="trash"/>
                    {{ $t('frosh-tools.tabs.fastly.purge') }}
                </button>
            </div>
        </div>
        <div class="ft-divider"></div>
        <div class="ft-toolbar ft-toolbar--spread">
            <div>
                <div class="frosh-tab-fastly__danger-title">Full cache purge</div>
                <div class="frosh-tab-fastly__danger-sub">Invalidates every cached object in this Fastly service.</div>
            </div>
            <button
                class="ft-btn ft-btn--danger"
                @click="onPurgeAll"
                :disabled="isLoading"
            >
                {{ $t('frosh-tools.tabs.fastly.purgeAll') }}
            </button>
        </div>
    </ft-panel>
    <ft-panel
        v-if="snippets && snippets.length > 0"
        :title="$t('frosh-tools.tabs.fastly.snippets.title')"
        :count="snippets.length"
        flush
    >
        <div class="ft-table-wrap">
            <table class="ft-table">
                <thead>
                    <tr>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('name') }"
                            @click="toggleSort('name')"
                        >
                            {{ $t('frosh-tools.tabs.fastly.snippets.name') }}
                            <ft-icon
                                v-if="sortDirOf('name')"
                                :name="sortDirOf('name') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('type') }"
                            @click="toggleSort('type')"
                        >
                            {{ $t('frosh-tools.tabs.fastly.snippets.type') }}
                            <ft-icon
                                v-if="sortDirOf('type')"
                                :name="sortDirOf('type') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__num ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('priority') }"
                            @click="toggleSort('priority')"
                        >
                            {{ $t('frosh-tools.tabs.fastly.snippets.priority') }}
                            <ft-icon
                                v-if="sortDirOf('priority')"
                                :name="sortDirOf('priority') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th class="ft-table__actions">
                            {{ $t('frosh-tools.actions') }}
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="item in sortRows(snippets)"
                        :key="item.name"
                    >
                        <td class="ft-table__name ft-mono">{{ item.name }}</td>
                        <td>
                            <ft-pill
                                variant="accent"
                                bare
                            >{{ item.type }}</ft-pill>
                        </td>
                        <td class="ft-table__num">{{ item.priority }}</td>
                        <td class="ft-table__actions">
                            <button
                                class="ft-btn"
                                @click="activeSnippet = item"
                            >
                                {{ $t('frosh-tools.tabs.fastly.snippets.view') }}
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
    <ft-modal
        v-if="activeSnippet"
        :title="activeSnippet.name"
        @close="activeSnippet = null"
        variant="large"
    >
        <div class="frosh-tab-fastly__editor">
            <sw-code-editor
                :value="activeSnippet.content"
                :readonly="true"
                mode="text"
                :softwraps="true"
                :setfocus="false"
            />
        </div>
        <template #footer>
            <button
                class="ft-btn"
                @click="activeSnippet = null"
            >
                {{ $t('global.default.close') }}
            </button>
        </template>
    </ft-modal>
</div>