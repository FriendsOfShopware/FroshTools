<div class="ft frosh-tab-fastly">
    <div class="ft-page-head">
        <div>
            <h1 class="ft-page-head__title">{{ $t('frosh-tools.tabs.fastly.title') }}</h1>
            <div class="ft-page-head__sub">Fastly cache observability and purge controls.</div>
        </div>
    </div>

    <section class="ft-panel">
        <div class="ft-panel__head">
            <h2 class="ft-panel__title">{{ $t('frosh-tools.tabs.fastly.statsTitle') }}</h2>
            <div class="ft-panel__actions frosh-tab-fastly__select">
                <sw-single-select
                    :placeholder="$t('frosh-tools.tabs.fastly.timeframeLabel')"
                    :options="timeframeOptions"
                    v-model:value="timeframe"
                    @update:value="loadStats"
                    :showSearch="false"
                    size="small"
                />
            </div>
        </div>
        <div class="ft-panel__body" v-if="!stats">
            <div class="ft-empty">
                <div class="ft-empty__icon"><ft-icon name="chart" :size="22" /></div>
                <div class="ft-empty__title">{{ $t('frosh-tools.tabs.fastly.emptyStats') }}</div>
            </div>
        </div>
        <div class="ft-panel__body" v-else>
            <div class="ft-stat-grid">
                <div class="ft-stat ft-stat--accent">
                    <div class="ft-stat__label">{{ $t('frosh-tools.tabs.fastly.requests') }}</div>
                    <div class="ft-stat__value">{{ formatNumber(stats.requests) }}</div>
                </div>
                <div class="ft-stat" :class="hitRateClass">
                    <div class="ft-stat__label">{{ $t('frosh-tools.tabs.fastly.hitRate') }}</div>
                    <div class="ft-stat__value">{{ formatNumber(stats.hit_ratio * 100) }}%</div>
                </div>
                <div class="ft-stat ft-stat--info">
                    <div class="ft-stat__label">{{ $t('frosh-tools.tabs.fastly.bandwidth') }}</div>
                    <div class="ft-stat__value">{{ formatSize(stats.bandwidth) }}</div>
                </div>
                <div class="ft-stat ft-stat--success">
                    <div class="ft-stat__label">{{ $t('frosh-tools.tabs.fastly.hits') }}</div>
                    <div class="ft-stat__value">{{ formatNumber(stats.hits) }}</div>
                </div>
            </div>
        </div>
    </section>

    <section class="ft-panel">
        <div class="ft-panel__head">
            <h2 class="ft-panel__title">Purge controls</h2>
        </div>
        <div class="ft-panel__body">
            <p class="frosh-tab-fastly__desc">{{ $t('frosh-tools.tabs.fastly.description') }}</p>

            <div class="frosh-tab-fastly__row">
                <div class="frosh-tab-fastly__row-grow">
                    <sw-text-field
                        v-model="purgePath"
                        :placeholder="$t('frosh-tools.tabs.fastly.placeholderPath')"
                        :label="$t('frosh-tools.tabs.fastly.purgePathLabel')"
                    />
                </div>
                <div class="frosh-tab-fastly__row-actions">
                    <button class="ft-btn" :disabled="!purgePath || isLoading" @click="onPurge">
                        <ft-icon name="trash" />
                        {{ $t('frosh-tools.tabs.fastly.purge') }}
                    </button>
                </div>
            </div>

            <div class="ft-divider"></div>

            <div class="ft-toolbar ft-toolbar--spread">
                <div>
                    <div class="frosh-tab-fastly__danger-title">Full cache purge</div>
                    <div class="frosh-tab-fastly__danger-sub">Invalidates every cached object in this Fastly service.</div>
                </div>
                <button class="ft-btn ft-btn--danger" @click="onPurgeAll" :disabled="isLoading">
                    {{ $t('frosh-tools.tabs.fastly.purgeAll') }}
                </button>
            </div>
        </div>
    </section>

    <section class="ft-panel" v-if="snippets && snippets.length > 0">
        <div class="ft-panel__head">
            <h2 class="ft-panel__title">
                {{ $t('frosh-tools.tabs.fastly.snippets.title') }}
                <span class="ft-panel__count">{{ snippets.length }}</span>
            </h2>
        </div>
        <div class="ft-panel__body ft-panel__body--flush">
            <div class="ft-table-wrap">
                <table class="ft-table">
                    <thead>
                        <tr>
                            <th>{{ $t('frosh-tools.tabs.fastly.snippets.name') }}</th>
                            <th>{{ $t('frosh-tools.tabs.fastly.snippets.type') }}</th>
                            <th class="ft-table__num">{{ $t('frosh-tools.tabs.fastly.snippets.priority') }}</th>
                            <th class="ft-table__actions">{{ $t('frosh-tools.actions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="item in snippets" :key="item.name">
                            <td class="ft-table__name ft-mono">{{ item.name }}</td>
                            <td><span class="ft-pill ft-pill--accent ft-pill--bare">{{ item.type }}</span></td>
                            <td class="ft-table__num">{{ item.priority }}</td>
                            <td class="ft-table__actions">
                                <button class="ft-btn" @click="activeSnippet = item">
                                    {{ $t('frosh-tools.tabs.fastly.snippets.view') }}
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <ft-modal v-if="activeSnippet" :title="activeSnippet.name" @close="activeSnippet = null" variant="large">
        <div class="frosh-tab-fastly__editor">
            <sw-code-editor
                :value="activeSnippet.content"
                :readonly="true"
                mode="text"
                :softwraps="true"
                :setfocus="false"
            />
        </div>
        <template #footer>
            <button class="ft-btn" @click="activeSnippet = null">{{ $t('global.default.close') }}</button>
        </template>
    </ft-modal>
</div>
