<div class="ft frosh-tab-flags">
    <div class="ft-page-head">
        <div>
            <h1 class="ft-page-head__title">{{ $tc('frosh-tools.tabs.feature-flags.title') }}</h1>
            <div class="ft-page-head__sub">Feature flags exposed by Shopware core and registered extensions.</div>
        </div>
        <div class="ft-page-head__actions">
            <button class="ft-btn" :disabled="isLoading" @click="createdComponent">
                <span v-if="isLoading" class="ft-spinner"></span>
                <ft-icon v-else name="refresh" />
                <span>Refresh</span>
            </button>
        </div>
    </div>

    <div class="ft-stat-grid">
        <div class="ft-stat ft-stat--success">
            <div class="ft-stat__label">Active</div>
            <div class="ft-stat__value">{{ activeCount }}</div>
        </div>
        <div class="ft-stat ft-stat--accent">
            <div class="ft-stat__label">Major</div>
            <div class="ft-stat__value">{{ majorCount }}</div>
        </div>
        <div class="ft-stat ft-stat--info">
            <div class="ft-stat__label">Default-on</div>
            <div class="ft-stat__value">{{ defaultCount }}</div>
        </div>
        <div class="ft-stat">
            <div class="ft-stat__label">Total</div>
            <div class="ft-stat__value">{{ featureFlags ? featureFlags.length : 0 }}</div>
        </div>
    </div>

    <section class="ft-panel">
        <div class="ft-panel__head">
            <h2 class="ft-panel__title">
                Flags
                <span class="ft-panel__count">{{ featureFlags ? featureFlags.length : 0 }}</span>
            </h2>
        </div>
        <div class="ft-panel__body ft-panel__body--flush">
            <div v-if="isLoading && !featureFlags" class="ft-empty">
                <span class="ft-spinner"></span>
            </div>
            <div v-else-if="!featureFlags || !featureFlags.length" class="ft-empty">
                <div class="ft-empty__title">No feature flags registered</div>
            </div>
            <div v-else class="ft-table-wrap">
                <table class="ft-table">
                    <thead>
                        <tr>
                            <th>{{ $t('frosh-tools.tabs.feature-flags.flag') }}</th>
                            <th>{{ $t('frosh-tools.tabs.feature-flags.description') }}</th>
                            <th style="width: 110px;">{{ $t('frosh-tools.active') }}</th>
                            <th style="width: 110px;">{{ $t('frosh-tools.tabs.feature-flags.major') }}</th>
                            <th style="width: 110px;">{{ $t('frosh-tools.tabs.feature-flags.default') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="item in featureFlags" :key="item.flag">
                            <td class="ft-table__name ft-mono">{{ item.flag }}</td>
                            <td>{{ item.description }}</td>
                            <td><span class="ft-pill" :class="item.active ? 'ft-pill--success' : 'ft-pill--muted'">{{ item.active ? 'on' : 'off' }}</span></td>
                            <td><span class="ft-pill" :class="item.major ? 'ft-pill--accent' : 'ft-pill--muted'">{{ item.major ? 'yes' : 'no' }}</span></td>
                            <td><span class="ft-pill" :class="item.default ? 'ft-pill--info' : 'ft-pill--muted'">{{ item.default ? 'yes' : 'no' }}</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>
