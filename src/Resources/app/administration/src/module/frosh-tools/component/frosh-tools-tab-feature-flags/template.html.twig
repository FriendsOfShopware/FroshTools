<div class="ft frosh-tab-flags">
    <ft-page-head
        :title="$tc('frosh-tools.tabs.feature-flags.title')"
        subtitle="Feature flags exposed by Shopware core and registered extensions."
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                label="Refresh"
                @click="createdComponent"
            />
        </template>
    </ft-page-head>
    <div class="ft-stat-grid">
        <ft-stat
            label="Active"
            :value="activeCount"
            variant="success"
        />
        <ft-stat
            label="Major"
            :value="majorCount"
            variant="accent"
        />
        <ft-stat
            label="Default-on"
            :value="defaultCount"
            variant="info"
        />
        <ft-stat
            label="Total"
            :value="featureFlags ? featureFlags.length : 0"
        />
    </div>
    <ft-panel
        title="Flags"
        :count="featureFlags ? featureFlags.length : 0"
        flush
    >
        <ft-empty
            v-if="isLoading && !featureFlags"
            loading
        />
        <ft-empty
            v-else-if="!featureFlags || !featureFlags.length"
            title="No feature flags registered"
        />
        <div
            v-else
            class="ft-table-wrap"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <th>
                            {{ $t('frosh-tools.tabs.feature-flags.flag') }}
                        </th>
                        <th>
                            {{ $t('frosh-tools.tabs.feature-flags.description') }}
                        </th>
                        <th style="width: 110px;">{{ $t('frosh-tools.active') }}</th>
                        <th style="width: 110px;">
                            {{ $t('frosh-tools.tabs.feature-flags.major') }}
                        </th>
                        <th style="width: 110px;">
                            {{ $t('frosh-tools.tabs.feature-flags.default') }}
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="item in featureFlags"
                        :key="item.flag"
                    >
                        <td class="ft-table__name ft-mono">{{ item.flag }}</td>
                        <td>{{ item.description }}</td>
                        <td>
                            <ft-pill :variant="item.active ? 'success' : 'muted'">
                                {{ item.active ? 'on' : 'off' }}
                            </ft-pill>
                        </td>
                        <td>
                            <ft-pill :variant="item.major ? 'accent' : 'muted'">
                                {{ item.major ? 'yes' : 'no' }}
                            </ft-pill>
                        </td>
                        <td>
                            <ft-pill :variant="item.default ? 'info' : 'muted'">
                                {{ item.default ? 'yes' : 'no' }}
                            </ft-pill>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
</div>