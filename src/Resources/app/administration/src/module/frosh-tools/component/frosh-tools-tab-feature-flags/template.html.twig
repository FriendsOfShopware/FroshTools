<div class="ft frosh-tab-flags">
    <ft-page-head
        :title="$tc('frosh-tools.tabs.feature-flags.title')"
        :subtitle="$t('frosh-tools.tabs.feature-flags.subtitle')"
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                @click="createdComponent"
            />
        </template>
    </ft-page-head>
    <ft-hero-state
        v-if="loadError"
        variant="danger"
        icon="alert"
        :title="$t('frosh-tools.loadError.title')"
        :body="loadError"
    >
        <template #actions>
            <ft-button
                icon="refresh"
                @click="refresh"
            >
                {{ $t('frosh-tools.loadError.retry') }}
            </ft-button>
        </template>
    </ft-hero-state>
    <ft-panel
        v-else
        :title="$t('frosh-tools.tabs.feature-flags.flags')"
        :count="featureFlags ? featureFlags.length : 0"
        flush
    >
        <ft-empty
            v-if="isLoading && !featureFlags"
            loading
        />
        <ft-empty
            v-else-if="!featureFlags || !featureFlags.length"
            :title="$t('frosh-tools.tabs.feature-flags.noFlags')"
        />
        <div
            v-else
            class="ft-table-wrap"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <ft-th-sort sort-key="flag">
                            {{ $t('frosh-tools.tabs.feature-flags.flag') }}
                        </ft-th-sort>
                        <ft-th-sort sort-key="description">
                            {{ $t('frosh-tools.tabs.feature-flags.description') }}
                        </ft-th-sort>
                        <ft-th-sort
                            sort-key="active"
                            style="width: 110px;"
                        >{{ $t('frosh-tools.active') }}</ft-th-sort>
                        <ft-th-sort
                            sort-key="major"
                            style="width: 110px;"
                        >
                            {{ $t('frosh-tools.tabs.feature-flags.major') }}
                        </ft-th-sort>
                        <ft-th-sort
                            sort-key="default"
                            style="width: 110px;"
                        >
                            {{ $t('frosh-tools.tabs.feature-flags.default') }}
                        </ft-th-sort>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="item in sortRows(featureFlags)"
                        :key="item.flag"
                    >
                        <td class="ft-table__name ft-mono">{{ item.flag }}</td>
                        <td>{{ item.description }}</td>
                        <td>
                            <ft-pill :variant="item.active ? 'success' : 'muted'">
                                {{ item.active ? $t('frosh-tools.on') : $t('frosh-tools.off') }}
                            </ft-pill>
                        </td>
                        <td>
                            <ft-pill :variant="item.major ? 'accent' : 'muted'">
                                {{ item.major ? $t('frosh-tools.yes') : $t('frosh-tools.no') }}
                            </ft-pill>
                        </td>
                        <td>
                            <ft-pill :variant="item.default ? 'info' : 'muted'">
                                {{ item.default ? $t('frosh-tools.yes') : $t('frosh-tools.no') }}
                            </ft-pill>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
</div>