<div class="ft frosh-tab-flags">
    <ft-page-head
        :title="$tc('frosh-tools.tabs.feature-flags.title')"
        subtitle="Feature flags exposed by Shopware core and registered extensions."
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                label="Refresh"
                @click="createdComponent"
            />
        </template>
    </ft-page-head>
    <ft-panel
        title="Flags"
        :count="featureFlags ? featureFlags.length : 0"
        flush
    >
        <ft-empty
            v-if="isLoading && !featureFlags"
            loading
        />
        <ft-empty
            v-else-if="!featureFlags || !featureFlags.length"
            title="No feature flags registered"
        />
        <div
            v-else
            class="ft-table-wrap"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('flag') }"
                            @click="toggleSort('flag')"
                        >
                            {{ $t('frosh-tools.tabs.feature-flags.flag') }}
                            <ft-icon
                                v-if="sortDirOf('flag')"
                                :name="sortDirOf('flag') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('description') }"
                            @click="toggleSort('description')"
                        >
                            {{ $t('frosh-tools.tabs.feature-flags.description') }}
                            <ft-icon
                                v-if="sortDirOf('description')"
                                :name="sortDirOf('description') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('active') }"
                            style="width: 110px;"
                            @click="toggleSort('active')"
                        >
                            {{ $t('frosh-tools.active') }}
                            <ft-icon
                                v-if="sortDirOf('active')"
                                :name="sortDirOf('active') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('major') }"
                            style="width: 110px;"
                            @click="toggleSort('major')"
                        >
                            {{ $t('frosh-tools.tabs.feature-flags.major') }}
                            <ft-icon
                                v-if="sortDirOf('major')"
                                :name="sortDirOf('major') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('default') }"
                            style="width: 110px;"
                            @click="toggleSort('default')"
                        >
                            {{ $t('frosh-tools.tabs.feature-flags.default') }}
                            <ft-icon
                                v-if="sortDirOf('default')"
                                :name="sortDirOf('default') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="item in sortRows(featureFlags)"
                        :key="item.flag"
                    >
                        <td class="ft-table__name ft-mono">{{ item.flag }}</td>
                        <td>{{ item.description }}</td>
                        <td>
                            <ft-pill :variant="item.active ? 'success' : 'muted'">
                                {{ item.active ? 'on' : 'off' }}
                            </ft-pill>
                        </td>
                        <td>
                            <ft-pill :variant="item.major ? 'accent' : 'muted'">
                                {{ item.major ? 'yes' : 'no' }}
                            </ft-pill>
                        </td>
                        <td>
                            <ft-pill :variant="item.default ? 'info' : 'muted'">
                                {{ item.default ? 'yes' : 'no' }}
                            </ft-pill>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
</div>