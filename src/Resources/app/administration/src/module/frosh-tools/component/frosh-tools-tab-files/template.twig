<div class="ft frosh-tab-files">
    <div class="ft-page-head">
        <div>
            <h1 class="ft-page-head__title">{{ $t('frosh-tools.tabs.files.title') }}</h1>
            <div class="ft-page-head__sub">Detect drift between shipped Shopware files and what's on disk.</div>
        </div>
        <div class="ft-page-head__actions">
            <button class="ft-btn" :disabled="isLoading" @click="refresh">
                <span v-if="isLoading" class="ft-spinner"></span>
                <ft-icon v-else name="refresh" />
                <span>Refresh</span>
            </button>
        </div>
    </div>

    <section class="ft-panel">
        <div class="ft-panel__head">
            <h2 class="ft-panel__title">
                Core
                <span class="ft-panel__count" v-if="items.files">{{ items.files.length }}</span>
            </h2>
        </div>
        <div class="ft-panel__body">
            <div v-if="items.error" class="ft-hero-state ft-hero-state--danger">
                <div class="ft-hero-state__icon"><ft-icon name="alert" :size="22" /></div>
                <div>
                    <div class="ft-hero-state__title">Check failed</div>
                    <div class="ft-hero-state__body">{{ items.error }}</div>
                </div>
            </div>
            <div v-else-if="items.ok" class="ft-hero-state ft-hero-state--success">
                <div class="ft-hero-state__icon"><ft-icon name="check" :size="22" /></div>
                <div>
                    <div class="ft-hero-state__title">{{ $t('frosh-tools.tabs.files.allFilesOk') }}</div>
                    <div class="ft-hero-state__body">Every shipped file matches its expected checksum.</div>
                </div>
            </div>
            <div v-else-if="items.files && items.files.length" class="ft-hero-state ft-hero-state--warning">
                <div class="ft-hero-state__icon"><ft-icon name="alert" :size="22" /></div>
                <div>
                    <div class="ft-hero-state__title">{{ $t('frosh-tools.tabs.files.notOk') }}</div>
                    <div class="ft-hero-state__body">{{ items.files.length }} file{{ items.files.length === 1 ? '' : 's' }} differ from the original.</div>
                </div>
            </div>
        </div>
        <div class="ft-panel__body ft-panel__body--flush" v-if="items.files && items.files.length">
            <div class="ft-table-wrap">
                <table class="ft-table">
                    <thead>
                        <tr>
                            <th>{{ $t('frosh-tools.name') }}</th>
                            <th>{{ $t('frosh-tools.status') }}</th>
                            <th class="ft-table__actions">{{ $t('frosh-tools.actions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="item in items.files" :key="item.name">
                            <td>
                                <a class="ft-link ft-mono" @click="diff(item)" :title="$t('frosh-tools.tabs.files.restore.diff')">{{ item.name }}</a>
                            </td>
                            <td>
                                <span class="ft-pill" :class="item.expected ? 'ft-pill--muted' : 'ft-pill--warning'">
                                    {{ item.expected ? $t('frosh-tools.tabs.files.expectedProject') : $t('frosh-tools.tabs.files.expectedAll') }}
                                </span>
                            </td>
                            <td class="ft-table__actions">
                                <button class="ft-btn ft-btn--ghost" @click="openUrl(item.shopwareUrl)">
                                    <ft-icon name="external-link" />
                                </button>
                                <button class="ft-btn" @click="diff(item)">
                                    {{ $t('frosh-tools.tabs.files.restore.diff') }}
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <ft-modal v-if="showModal" variant="large" @close="closeModal" :title="diffData.file.name">
        <pre class="ft-diff" v-html="diffData.html"></pre>
        <template #footer>
            <button class="ft-btn" @click="closeModal">{{ $t('global.default.close') }}</button>
            <button class="ft-btn ft-btn--danger" @click="restoreFile(diffData.file.name)" :disabled="diffData.file.expected">
                <ft-icon name="alert" />
                {{ $t('frosh-tools.tabs.files.restore.restoreFile') }}
            </button>
        </template>
    </ft-modal>

    <section class="ft-panel">
        <div class="ft-panel__head">
            <h2 class="ft-panel__title">{{ $t('frosh-tools.tabs.extensionFiles.title') }}</h2>
        </div>
        <div class="ft-panel__body">
            <div v-if="extensionItems.success" class="ft-hero-state ft-hero-state--success">
                <div class="ft-hero-state__icon"><ft-icon name="check" :size="22" /></div>
                <div>
                    <div class="ft-hero-state__title">{{ $t('frosh-tools.tabs.extensionFiles.allFilesOk') }}</div>
                </div>
            </div>
            <div v-else class="ft-hero-state ft-hero-state--warning">
                <div class="ft-hero-state__icon"><ft-icon name="alert" :size="22" /></div>
                <div>
                    <div class="ft-hero-state__title">{{ $t('frosh-tools.tabs.extensionFiles.notOk') }}</div>
                </div>
            </div>

            <div
                v-for="(extensionResult, extensionName) in extensionItems.extensionResults"
                :key="extensionName"
                class="frosh-tab-files__ext"
            >
                <div class="frosh-tab-files__ext-head">
                    <span class="ft-pill ft-pill--accent ft-pill--bare">extension</span>
                    <h3 class="frosh-tab-files__ext-name">{{ extensionName }}</h3>
                </div>

                <div v-if="extensionResult.wrongExtensionVersion" class="ft-hero-state ft-hero-state--warning">
                    <div class="ft-hero-state__icon"><ft-icon name="alert" :size="22" /></div>
                    <div><div class="ft-hero-state__title">{{ $t('frosh-tools.tabs.extensionFiles.wrongExtensionVersion') }}</div></div>
                </div>
                <div v-else-if="extensionResult.checkFailed" class="ft-hero-state ft-hero-state--danger">
                    <div class="ft-hero-state__icon"><ft-icon name="alert" :size="22" /></div>
                    <div><div class="ft-hero-state__title">{{ $t('frosh-tools.tabs.extensionFiles.checkFailed') }}</div></div>
                </div>
                <div v-else class="frosh-tab-files__ext-grid">
                    <div v-if="extensionResult.newFiles.length > 0" class="frosh-tab-files__ext-group">
                        <div class="frosh-tab-files__ext-label">
                            <span class="ft-pill ft-pill--info ft-pill--bare">new</span>
                            {{ $t('frosh-tools.tabs.extensionFiles.newFiles') }}
                            <span class="ft-panel__count">{{ extensionResult.newFiles.length }}</span>
                        </div>
                        <ul class="frosh-tab-files__ext-list">
                            <li v-for="f in extensionResult.newFiles" :key="`n-${f}`" class="ft-mono">{{ f }}</li>
                        </ul>
                    </div>
                    <div v-if="extensionResult.changedFiles.length > 0" class="frosh-tab-files__ext-group">
                        <div class="frosh-tab-files__ext-label">
                            <span class="ft-pill ft-pill--warning ft-pill--bare">changed</span>
                            {{ $t('frosh-tools.tabs.extensionFiles.changedFiles') }}
                            <span class="ft-panel__count">{{ extensionResult.changedFiles.length }}</span>
                        </div>
                        <ul class="frosh-tab-files__ext-list">
                            <li v-for="f in extensionResult.changedFiles" :key="`c-${f}`" class="ft-mono">{{ f }}</li>
                        </ul>
                    </div>
                    <div v-if="extensionResult.missingFiles.length > 0" class="frosh-tab-files__ext-group">
                        <div class="frosh-tab-files__ext-label">
                            <span class="ft-pill ft-pill--danger ft-pill--bare">missing</span>
                            {{ $t('frosh-tools.tabs.extensionFiles.missingFiles') }}
                            <span class="ft-panel__count">{{ extensionResult.missingFiles.length }}</span>
                        </div>
                        <ul class="frosh-tab-files__ext-list">
                            <li v-for="f in extensionResult.missingFiles" :key="`m-${f}`" class="ft-mono">{{ f }}</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
