<div class="ft frosh-tab-index">
    <div class="ft-page-head">
        <div>
            <h1 class="ft-page-head__title">{{ $t('frosh-tools.tabs.index.title') }}</h1>
            <div class="ft-page-head__sub">Live health and performance checks for this Shopware instance.</div>
        </div>
        <div class="ft-page-head__actions">
            <button
                class="ft-btn"
                :disabled="isLoading"
                @click="refresh"
            >
                <span v-if="isLoading" class="ft-spinner"></span>
                <ft-icon v-else name="refresh" />
                <span>Refresh</span>
            </button>
        </div>
    </div>

    <div class="ft-stat-grid">
        <div class="ft-stat" :class="errorCount > 0 ? 'ft-stat--danger' : 'ft-stat--success'">
            <div class="ft-stat__label">Errors</div>
            <div class="ft-stat__value">{{ errorCount }}</div>
            <div class="ft-stat__hint">Critical issues to resolve</div>
        </div>
        <div class="ft-stat" :class="warningCount > 0 ? 'ft-stat--warning' : 'ft-stat--success'">
            <div class="ft-stat__label">Warnings</div>
            <div class="ft-stat__value">{{ warningCount }}</div>
            <div class="ft-stat__hint">Should be reviewed</div>
        </div>
        <div class="ft-stat ft-stat--info">
            <div class="ft-stat__label">Info</div>
            <div class="ft-stat__value">{{ infoCount }}</div>
            <div class="ft-stat__hint">Informational signals</div>
        </div>
        <div class="ft-stat ft-stat--accent">
            <div class="ft-stat__label">Recommendations</div>
            <div class="ft-stat__value">{{ recommendationCount }}</div>
            <div class="ft-stat__hint">Performance tips</div>
        </div>
    </div>

    <section class="ft-panel">
        <div class="ft-panel__head">
            <h2 class="ft-panel__title">
                System Health
                <span class="ft-panel__count">{{ health ? health.length : 0 }}</span>
            </h2>
        </div>
        <div class="ft-panel__body ft-panel__body--flush">
            <div v-if="isLoading && !health" class="ft-empty">
                <span class="ft-spinner"></span>
            </div>
            <div v-else-if="!health || health.length === 0" class="ft-empty">
                <div class="ft-empty__title">No health checks reported</div>
            </div>
            <div v-else class="ft-table-wrap">
                <table class="ft-table">
                    <thead>
                        <tr>
                            <th style="width: 110px;">Status</th>
                            <th>{{ $t('frosh-tools.name') }}</th>
                            <th>{{ $t('frosh-tools.current') }}</th>
                            <th>{{ $t('frosh-tools.recommended') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="(item, idx) in health" :key="`h-${idx}`">
                            <td>
                                <span class="ft-pill" :class="pillClass(item.state)">{{ stateLabel(item.state) }}</span>
                            </td>
                            <td class="ft-table__name">
                                {{ item.snippet }}
                                <a v-if="item.url" class="ft-link" :href="item.url" target="_blank" rel="noopener">
                                    {{ $t('frosh-tools.tabs.index.info') }}
                                </a>
                            </td>
                            <td class="ft-mono">{{ item.current }}</td>
                            <td class="ft-mono">{{ item.recommended }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <section class="ft-panel">
        <div class="ft-panel__head">
            <h2 class="ft-panel__title">
                {{ $t('frosh-tools.tabs.index.performance') }}
                <span class="ft-panel__count">{{ performanceStatus ? performanceStatus.length : 0 }}</span>
            </h2>
        </div>
        <div class="ft-panel__body" v-if="!isLoading && performanceStatus && performanceStatus.length === 0">
            <div class="ft-hero-state ft-hero-state--success">
                <div class="ft-hero-state__icon">
                    <ft-icon name="check" :size="20" />
                </div>
                <div>
                    <div class="ft-hero-state__title">All clear</div>
                    <div class="ft-hero-state__body">{{ $t('frosh-tools.noRecommendations') }}</div>
                </div>
            </div>
        </div>
        <div class="ft-panel__body ft-panel__body--flush" v-else-if="performanceStatus && performanceStatus.length > 0">
            <div class="ft-table-wrap">
                <table class="ft-table">
                    <thead>
                        <tr>
                            <th style="width: 110px;">Status</th>
                            <th>{{ $t('frosh-tools.name') }}</th>
                            <th>{{ $t('frosh-tools.current') }}</th>
                            <th>{{ $t('frosh-tools.recommended') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="(item, idx) in performanceStatus" :key="`p-${idx}`">
                            <td>
                                <span class="ft-pill" :class="pillClass(item.state)">{{ stateLabel(item.state) }}</span>
                            </td>
                            <td class="ft-table__name">
                                {{ item.snippet }}
                                <a v-if="item.url" class="ft-link" :href="item.url" target="_blank" rel="noopener">
                                    {{ $t('frosh-tools.tabs.index.info') }}
                                </a>
                            </td>
                            <td class="ft-mono">{{ item.current }}</td>
                            <td class="ft-mono">{{ item.recommended }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>
