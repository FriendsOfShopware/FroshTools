<div class="ft frosh-tab-index">
    <ft-page-head
        :title="$t('frosh-tools.tabs.index.title')"
        subtitle="Live health and performance checks for this Shopware instance."
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                label="Refresh"
                @click="refresh"
            />
        </template>
    </ft-page-head>
    <div class="ft-stat-grid">
        <ft-stat
            :label="$t('frosh-tools.error')"
            :value="errorCount"
            :variant="errorCount > 0 ? 'danger' : 'success'"
            hint="Critical issues to resolve"
        />
        <ft-stat
            :label="$t('frosh-tools.warning')"
            :value="warningCount"
            :variant="warningCount > 0 ? 'warning' : 'success'"
            hint="Should be reviewed"
        />
        <ft-stat
            :label="$t('frosh-tools.info')"
            :value="infoCount"
            variant="info"
            hint="Informational signals"
        />
        <ft-stat
            label="Recommendations"
            :value="recommendationCount"
            variant="accent"
            hint="Performance tips"
        />
    </div>
    <ft-panel
        title="System Health"
        :count="health ? health.length : 0"
        flush
    >
        <ft-empty
            v-if="isLoading && !health"
            loading
        />
        <ft-empty
            v-else-if="!health || health.length === 0"
            title="No health checks reported"
        />
        <div
            v-else
            class="ft-table-wrap"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <th style="width: 110px;">Status</th>
                        <th>{{ $t('frosh-tools.name') }}</th>
                        <th>
                            {{ $t('frosh-tools.current') }}
                        </th>
                        <th>
                            {{ $t('frosh-tools.recommended') }}
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="(item, idx) in health"
                        :key="`h-${idx}`"
                    >
                        <td>
                            <ft-pill :variant="pillVariant(item.state)">{{ stateLabel(item.state) }}</ft-pill>
                        </td>
                        <td class="ft-table__name">
                            {{ item.snippet }}
                            <a
                                v-if="item.url"
                                class="ft-link"
                                :href="item.url"
                                target="_blank"
                                rel="noopener"
                            >
                                {{ $t('frosh-tools.tabs.index.info') }}
                            </a>
                        </td>
                        <td class="ft-mono">{{ item.current }}</td>
                        <td class="ft-mono">{{ item.recommended }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
    <ft-panel
        :title="$t('frosh-tools.tabs.index.performance')"
        :count="performanceStatus ? performanceStatus.length : 0"
        :flush="!(performanceStatus && performanceStatus.length === 0)"
    >
        <ft-hero-state
            v-if="!isLoading && performanceStatus && performanceStatus.length === 0"
            variant="success"
            icon="check"
            title="All clear"
            :body="$t('frosh-tools.noRecommendations')"
        />
        <div
            class="ft-table-wrap"
            v-else-if="performanceStatus && performanceStatus.length > 0"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <th style="width: 110px;">Status</th>
                        <th>{{ $t('frosh-tools.name') }}</th>
                        <th>
                            {{ $t('frosh-tools.current') }}
                        </th>
                        <th>
                            {{ $t('frosh-tools.recommended') }}
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="(item, idx) in performanceStatus"
                        :key="`p-${idx}`"
                    >
                        <td>
                            <ft-pill :variant="pillVariant(item.state)">{{ stateLabel(item.state) }}</ft-pill>
                        </td>
                        <td class="ft-table__name">
                            {{ item.snippet }}
                            <a
                                v-if="item.url"
                                class="ft-link"
                                :href="item.url"
                                target="_blank"
                                rel="noopener"
                            >
                                {{ $t('frosh-tools.tabs.index.info') }}
                            </a>
                        </td>
                        <td class="ft-mono">{{ item.current }}</td>
                        <td class="ft-mono">{{ item.recommended }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
</div>