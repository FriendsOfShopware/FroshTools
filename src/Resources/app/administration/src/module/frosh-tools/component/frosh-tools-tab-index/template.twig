<div class="ft frosh-tab-index">
    <ft-page-head
        :title="$t('frosh-tools.tabs.index.title')"
        subtitle="Live health and performance checks for this Shopware instance."
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                label="Refresh"
                @click="refresh"
            />
        </template>
    </ft-page-head>
    <ft-panel
        title="System Health"
        :count="health ? health.length : 0"
        flush
    >
        <ft-empty
            v-if="isLoading && !health"
            loading
        />
        <ft-empty
            v-else-if="!health || health.length === 0"
            title="No health checks reported"
        />
        <div
            v-else
            class="ft-table-wrap"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <ft-th-sort
                            sort-key="state"
                            table="health"
                            style="width: 110px;"
                        >Status</ft-th-sort>
                        <ft-th-sort
                            sort-key="snippet"
                            table="health"
                        >{{ $t('frosh-tools.name') }}</ft-th-sort>
                        <ft-th-sort
                            sort-key="current"
                            table="health"
                        >
                            {{ $t('frosh-tools.current') }}
                        </ft-th-sort>
                        <ft-th-sort
                            sort-key="recommended"
                            table="health"
                        >
                            {{ $t('frosh-tools.recommended') }}
                        </ft-th-sort>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="(item, idx) in sortRows(health, 'health')"
                        :key="`h-${idx}`"
                    >
                        <td>
                            <ft-pill :variant="pillVariant(item.state)">{{ stateLabel(item.state) }}</ft-pill>
                        </td>
                        <td class="ft-table__name">
                            {{ item.snippet }}
                            <a
                                v-if="item.url"
                                class="ft-link"
                                :href="item.url"
                                target="_blank"
                                rel="noopener"
                            >
                                {{ $t('frosh-tools.tabs.index.info') }}
                            </a>
                        </td>
                        <td class="ft-mono">{{ item.current }}</td>
                        <td class="ft-mono">{{ item.recommended }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
    <ft-panel
        :title="$t('frosh-tools.tabs.index.performance')"
        :count="performanceStatus ? performanceStatus.length : 0"
        :flush="!(performanceStatus && performanceStatus.length === 0)"
    >
        <ft-hero-state
            v-if="!isLoading && performanceStatus && performanceStatus.length === 0"
            variant="success"
            icon="check"
            title="All clear"
            :body="$t('frosh-tools.noRecommendations')"
        />
        <div
            class="ft-table-wrap"
            v-else-if="performanceStatus && performanceStatus.length > 0"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <ft-th-sort
                            sort-key="state"
                            table="performance"
                            style="width: 110px;"
                        >Status</ft-th-sort>
                        <ft-th-sort
                            sort-key="snippet"
                            table="performance"
                        >{{ $t('frosh-tools.name') }}</ft-th-sort>
                        <ft-th-sort
                            sort-key="current"
                            table="performance"
                        >
                            {{ $t('frosh-tools.current') }}
                        </ft-th-sort>
                        <ft-th-sort
                            sort-key="recommended"
                            table="performance"
                        >
                            {{ $t('frosh-tools.recommended') }}
                        </ft-th-sort>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="(item, idx) in sortRows(performanceStatus, 'performance')"
                        :key="`p-${idx}`"
                    >
                        <td>
                            <ft-pill :variant="pillVariant(item.state)">{{ stateLabel(item.state) }}</ft-pill>
                        </td>
                        <td class="ft-table__name">
                            {{ item.snippet }}
                            <a
                                v-if="item.url"
                                class="ft-link"
                                :href="item.url"
                                target="_blank"
                                rel="noopener"
                            >
                                {{ $t('frosh-tools.tabs.index.info') }}
                            </a>
                        </td>
                        <td class="ft-mono">{{ item.current }}</td>
                        <td class="ft-mono">{{ item.recommended }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
</div>