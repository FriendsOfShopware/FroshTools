{% block frosh_tools_tab_logs %}
<div class="ft frosh-tab-logs">
    {% block frosh_tools_tab_logs_head %}
    <ft-page-head
        :title="$t('frosh-tools.tabs.logs.title')"
        subtitle="Stream and inspect entries from any log file on disk."
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                label="Refresh"
                @click="refresh"
            />
        </template>
    </ft-page-head>
    {% endblock %}
    {% block frosh_tools_tab_logs_panel %}
    <ft-panel
        title="Log file"
        flush
    >
        <template #actions>
            <div class="frosh-tab-logs__select">
                <sw-single-select
                    :options="logFiles"
                    :isLoading="isLoading"
                    :placeholder="$t('frosh-tools.tabs.logs.logFileSelect.placeholder')"
                    labelProperty="name"
                    valueProperty="name"
                    v-model:value="selectedLogFile"
                    @update:value="onFileSelected"
                />
            </div>
        </template>
        <ft-empty
            v-if="!selectedLogFile"
            icon="file"
            title="Select a log file"
            sub="Choose a file above to view its entries."
        />
        <ft-empty
            v-else-if="!logEntries.length"
            title="No entries in this file"
        />
        <div
            v-else
            class="ft-table-wrap"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <th style="width: 170px;">{{ $t('frosh-tools.date') }}</th>
                        <th style="width: 130px;">
                            {{ $t('frosh-tools.channel') }}
                        </th>
                        <th style="width: 110px;">{{ $t('frosh-tools.level') }}</th>
                        <th>
                            {{ $t('frosh-tools.message') }}
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="(item, idx) in logEntries"
                        :key="idx"
                    >
                        <td class="ft-mono">
                            {{ date(item.date, {hour: '2-digit', minute: '2-digit', second: '2-digit'}) }}
                        </td>
                        <td>
                            <ft-pill
                                variant="muted"
                                bare
                            >{{ item.channel }}</ft-pill>
                        </td>
                        <td>
                            <ft-pill :variant="levelVariant(item.level)">{{ item.level }}</ft-pill>
                        </td>
                        <td>
                            <a
                                class="ft-link"
                                @click="showInfoModal(item)"
                            >{{ truncate(item.message) }}</a>
                        </td>
                    </tr>
                </tbody>
            </table>
            <div class="frosh-tab-logs__pagination">
                <sw-pagination
                    :total="totalLogEntries"
                    :limit="limit"
                    :page="page"
                    @page-change="onPageChange"
                />
            </div>
        </div>
    </ft-panel>
    {% endblock %}
    {% block frosh_tools_tab_logs_modal %}
    <ft-modal
        v-if="displayedLog"
        variant="large"
        @close="closeInfoModal"
    >
        <template #header>
            {% block frosh_tools_tab_logs_modal_header %}
            <div class="frosh-tab-logs__modal-head">
                <div class="frosh-tab-logs__modal-title">
                    <ft-pill
                        variant="muted"
                        bare
                    >{{ displayedLog.channel }}</ft-pill>
                    <ft-pill :variant="levelVariant(displayedLog.level)">{{ displayedLog.level }}</ft-pill>
                </div>
                <div class="frosh-tab-logs__modal-date ft-mono">
                    {{ date(displayedLog.date, {hour: '2-digit', minute: '2-digit', second: '2-digit'}) }}
                </div>
            </div>
            {% endblock %}
        </template>
        {% block frosh_tools_tab_logs_modal_message %}
        <pre class="ft-diff frosh-tab-logs__message">{{ formatMessage(displayedLog.message) }}</pre>
        {% endblock %}
    </ft-modal>
    {% endblock %}
</div>
{% endblock %}
