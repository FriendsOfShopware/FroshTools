<div class="ft frosh-tab-logs">
    <ft-page-head
        :title="$t('frosh-tools.tabs.logs.title')"
        :subtitle="$t('frosh-tools.tabs.logs.subtitle')"
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                @click="refresh"
            />
        </template>
    </ft-page-head>
    <ft-hero-state
        v-if="loadError"
        variant="danger"
        icon="alert"
        :title="$t('frosh-tools.loadError.title')"
        :body="loadError"
    >
        <template #actions>
            <ft-button
                icon="refresh"
                @click="refresh"
            >
                {{ $t('frosh-tools.loadError.retry') }}
            </ft-button>
        </template>
    </ft-hero-state>
    <ft-panel
        v-else
        :title="$t('frosh-tools.tabs.logs.panelTitle')"
        flush
    >
        <template #actions>
            <div class="frosh-tab-logs__select">
                <sw-single-select
                    :options="logFiles"
                    :isLoading="isLoading"
                    :placeholder="$t('frosh-tools.tabs.logs.logFileSelect.placeholder')"
                    labelProperty="name"
                    valueProperty="name"
                    v-model:value="selectedLogFile"
                    @update:value="onFileSelected"
                />
            </div>
        </template>
        <ft-empty
            v-if="!selectedLogFile"
            icon="file"
            :title="$t('frosh-tools.tabs.logs.selectFile')"
            :sub="$t('frosh-tools.tabs.logs.selectFileHint')"
        />
        <ft-empty
            v-else-if="isLoadingEntries && !logEntries.length"
            loading
        />
        <ft-empty
            v-else-if="!logEntries.length"
            :title="$t('frosh-tools.tabs.logs.noEntries')"
        />
        <div
            v-else
            class="ft-table-wrap"
            :class="{ 'ft-loading-overlay': isLoadingEntries }"
            :aria-busy="isLoadingEntries ? 'true' : null"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <ft-th-sort
                            sort-key="date"
                            style="width: 170px;"
                        >{{ $t('frosh-tools.date') }}</ft-th-sort>
                        <ft-th-sort
                            sort-key="channel"
                            style="width: 130px;"
                        >
                            {{ $t('frosh-tools.channel') }}
                        </ft-th-sort>
                        <ft-th-sort
                            sort-key="level"
                            style="width: 110px;"
                        >{{ $t('frosh-tools.level') }}</ft-th-sort>
                        <ft-th-sort sort-key="message">
                            {{ $t('frosh-tools.message') }}
                        </ft-th-sort>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="(item, idx) in sortRows(logEntries)"
                        :key="idx"
                    >
                        <td class="ft-mono">
                            {{ date(item.date, {hour: '2-digit', minute: '2-digit', second: '2-digit'}) }}
                        </td>
                        <td>
                            <ft-pill
                                variant="muted"
                                bare
                            >{{ item.channel }}</ft-pill>
                        </td>
                        <td>
                            <ft-pill :variant="levelVariant(item.level)">{{ item.level }}</ft-pill>
                        </td>
                        <td>
                            <button
                                type="button"
                                class="ft-link frosh-tab-logs__message-trigger"
                                @click="showInfoModal(item)"
                            >{{ truncate(item.message) }}</button>
                        </td>
                    </tr>
                </tbody>
            </table>
            <div class="frosh-tab-logs__pagination">
                <sw-pagination
                    :total="totalLogEntries"
                    :limit="limit"
                    :page="page"
                    @page-change="onPageChange"
                />
            </div>
        </div>
    </ft-panel>
    <ft-modal
        v-if="displayedLog"
        variant="large"
        @close="closeInfoModal"
    >
        <template #header>
            <div class="frosh-tab-logs__modal-head">
                <div class="frosh-tab-logs__modal-title">
                    <ft-pill
                        variant="muted"
                        bare
                    >{{ displayedLog.channel }}</ft-pill>
                    <ft-pill :variant="levelVariant(displayedLog.level)">{{ displayedLog.level }}</ft-pill>
                </div>
                <div class="frosh-tab-logs__modal-date ft-mono">
                    {{ date(displayedLog.date, {hour: '2-digit', minute: '2-digit', second: '2-digit'}) }}
                </div>
            </div>
        </template>
        <pre class="ft-diff frosh-tab-logs__message">{{ displayedLog.message }}</pre>
    </ft-modal>
</div>