<div class="ft frosh-tab-logs">
    <div class="ft-page-head">
        <div>
            <h1 class="ft-page-head__title">{{ $t('frosh-tools.tabs.logs.title') }}</h1>
            <div class="ft-page-head__sub">Stream and inspect entries from any log file on disk.</div>
        </div>
        <div class="ft-page-head__actions">
            <button class="ft-btn" :disabled="isLoading" @click="refresh">
                <span v-if="isLoading" class="ft-spinner"></span>
                <ft-icon v-else name="refresh" />
                <span>Refresh</span>
            </button>
        </div>
    </div>

    <section class="ft-panel">
        <div class="ft-panel__head">
            <h2 class="ft-panel__title">Log file</h2>
            <div class="ft-panel__actions frosh-tab-logs__select">
                <sw-single-select
                    :options="logFiles"
                    :isLoading="isLoading"
                    :placeholder="$t('frosh-tools.tabs.logs.logFileSelect.placeholder')"
                    labelProperty="name"
                    valueProperty="name"
                    v-model:value="selectedLogFile"
                    @update:value="onFileSelected"
                />
            </div>
        </div>
        <div class="ft-panel__body ft-panel__body--flush">
            <div v-if="!selectedLogFile" class="ft-empty">
                <div class="ft-empty__icon">
                    <ft-icon name="file" :size="22" />
                </div>
                <div class="ft-empty__title">Select a log file</div>
                <div class="ft-empty__sub">Choose a file above to view its entries.</div>
            </div>
            <div v-else-if="!logEntries.length" class="ft-empty">
                <div class="ft-empty__title">No entries in this file</div>
            </div>
            <div v-else class="ft-table-wrap">
                <table class="ft-table">
                    <thead>
                        <tr>
                            <th style="width: 170px;">{{ $t('frosh-tools.date') }}</th>
                            <th style="width: 130px;">{{ $t('frosh-tools.channel') }}</th>
                            <th style="width: 110px;">{{ $t('frosh-tools.level') }}</th>
                            <th>{{ $t('frosh-tools.message') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="(item, idx) in logEntries" :key="idx">
                            <td class="ft-mono">{{ date(item.date, {hour: '2-digit', minute: '2-digit', second: '2-digit'}) }}</td>
                            <td><span class="ft-pill ft-pill--muted ft-pill--bare">{{ item.channel }}</span></td>
                            <td><span class="ft-pill" :class="levelPill(item.level)">{{ item.level }}</span></td>
                            <td>
                                <a class="ft-link" @click="showInfoModal(item)">{{ truncate(item.message) }}</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div class="frosh-tab-logs__pagination">
                    <sw-pagination
                        :total="totalLogEntries"
                        :limit="limit"
                        :page="page"
                        @page-change="onPageChange"
                    />
                </div>
            </div>
        </div>
    </section>

    <ft-modal v-if="displayedLog" variant="large" @close="closeInfoModal">
        <template #header>
            <div class="frosh-tab-logs__modal-head">
                <div class="frosh-tab-logs__modal-title">
                    <span class="ft-pill ft-pill--muted ft-pill--bare">{{ displayedLog.channel }}</span>
                    <span class="ft-pill" :class="levelPill(displayedLog.level)">{{ displayedLog.level }}</span>
                </div>
                <div class="frosh-tab-logs__modal-date ft-mono">
                    {{ date(displayedLog.date, {hour: '2-digit', minute: '2-digit', second: '2-digit'}) }}
                </div>
            </div>
        </template>
        <pre class="ft-diff frosh-tab-logs__message">{{ displayedLog.message }}</pre>
    </ft-modal>
</div>
