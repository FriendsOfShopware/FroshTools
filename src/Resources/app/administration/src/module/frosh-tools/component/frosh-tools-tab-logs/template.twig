<div class="ft frosh-tab-logs">
    <ft-page-head
        :title="$t('frosh-tools.tabs.logs.title')"
        subtitle="Stream and inspect entries from any log file on disk."
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                label="Refresh"
                @click="refresh"
            />
        </template>
    </ft-page-head>
    <ft-panel
        title="Log file"
        flush
    >
        <template #actions>
            <div class="frosh-tab-logs__select">
                <sw-single-select
                    :options="logFiles"
                    :isLoading="isLoading"
                    :placeholder="$t('frosh-tools.tabs.logs.logFileSelect.placeholder')"
                    labelProperty="name"
                    valueProperty="name"
                    v-model:value="selectedLogFile"
                    @update:value="onFileSelected"
                />
            </div>
        </template>
        <ft-empty
            v-if="!selectedLogFile"
            icon="file"
            title="Select a log file"
            sub="Choose a file above to view its entries."
        />
        <ft-empty
            v-else-if="!logEntries.length"
            title="No entries in this file"
        />
        <div
            v-else
            class="ft-table-wrap"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('date') }"
                            style="width: 170px;"
                            @click="toggleSort('date')"
                        >
                            {{ $t('frosh-tools.date') }}
                            <ft-icon
                                v-if="sortDirOf('date')"
                                :name="sortDirOf('date') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('channel') }"
                            style="width: 130px;"
                            @click="toggleSort('channel')"
                        >
                            {{ $t('frosh-tools.channel') }}
                            <ft-icon
                                v-if="sortDirOf('channel')"
                                :name="sortDirOf('channel') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('level') }"
                            style="width: 110px;"
                            @click="toggleSort('level')"
                        >
                            {{ $t('frosh-tools.level') }}
                            <ft-icon
                                v-if="sortDirOf('level')"
                                :name="sortDirOf('level') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('message') }"
                            @click="toggleSort('message')"
                        >
                            {{ $t('frosh-tools.message') }}
                            <ft-icon
                                v-if="sortDirOf('message')"
                                :name="sortDirOf('message') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="(item, idx) in sortRows(logEntries)"
                        :key="idx"
                    >
                        <td class="ft-mono">
                            {{ date(item.date, {hour: '2-digit', minute: '2-digit', second: '2-digit'}) }}
                        </td>
                        <td>
                            <ft-pill
                                variant="muted"
                                bare
                            >{{ item.channel }}</ft-pill>
                        </td>
                        <td>
                            <ft-pill :variant="levelVariant(item.level)">{{ item.level }}</ft-pill>
                        </td>
                        <td>
                            <a
                                class="ft-link"
                                @click="showInfoModal(item)"
                            >{{ truncate(item.message) }}</a>
                        </td>
                    </tr>
                </tbody>
            </table>
            <div class="frosh-tab-logs__pagination">
                <sw-pagination
                    :total="totalLogEntries"
                    :limit="limit"
                    :page="page"
                    @page-change="onPageChange"
                />
            </div>
        </div>
    </ft-panel>
    <ft-modal
        v-if="displayedLog"
        variant="large"
        @close="closeInfoModal"
    >
        <template #header>
            <div class="frosh-tab-logs__modal-head">
                <div class="frosh-tab-logs__modal-title">
                    <ft-pill
                        variant="muted"
                        bare
                    >{{ displayedLog.channel }}</ft-pill>
                    <ft-pill :variant="levelVariant(displayedLog.level)">{{ displayedLog.level }}</ft-pill>
                </div>
                <div class="frosh-tab-logs__modal-date ft-mono">
                    {{ date(displayedLog.date, {hour: '2-digit', minute: '2-digit', second: '2-digit'}) }}
                </div>
            </div>
        </template>
        <pre class="ft-diff frosh-tab-logs__message">{{ displayedLog.message }}</pre>
    </ft-modal>
</div>