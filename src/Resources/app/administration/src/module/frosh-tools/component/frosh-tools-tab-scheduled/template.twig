<div class="ft frosh-tab-scheduled">
    <ft-page-head
        :title="$t('frosh-tools.tabs.scheduledTaskOverview.title')"
        subtitle="Inspect, schedule, deactivate and run background tasks."
    >
        <template #actions>
            <ft-refresh-button
                :loading="isLoading"
                label="Refresh"
                @click="refresh"
            />
            <button
                class="ft-btn ft-btn--primary"
                :disabled="isLoading"
                @click="registerScheduledTasks"
            >
                <ft-icon name="cog"/>
                <span>
                    {{ $t('frosh-tools.scheduledTasksRegisterStarted') }}
                </span>
            </button>
        </template>
    </ft-page-head>
    <ft-panel
        title="Tasks"
        :count="items ? items.length : null"
        flush
    >
        <ft-empty
            v-if="!items"
            loading
        />
        <ft-empty
            v-else-if="!items.length"
            title="No scheduled tasks registered"
        />
        <div
            v-else
            class="ft-table-wrap"
        >
            <table class="ft-table">
                <thead>
                    <tr>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('name') }"
                            @click="toggleSort('name')"
                        >
                            {{ $t('frosh-tools.name') }}
                            <ft-icon
                                v-if="sortDirOf('name')"
                                :name="sortDirOf('name') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__num ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('runInterval') }"
                            @click="toggleSort('runInterval')"
                        >
                            {{ $t('frosh-tools.interval') }}
                            <ft-icon
                                v-if="sortDirOf('runInterval')"
                                :name="sortDirOf('runInterval') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('lastExecutionTime') }"
                            @click="toggleSort('lastExecutionTime')"
                        >
                            {{ $t('frosh-tools.lastExecutionTime') }}
                            <ft-icon
                                v-if="sortDirOf('lastExecutionTime')"
                                :name="sortDirOf('lastExecutionTime') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('nextExecutionTime') }"
                            @click="toggleSort('nextExecutionTime')"
                        >
                            {{ $t('frosh-tools.nextExecutionTime') }}
                            <ft-icon
                                v-if="sortDirOf('nextExecutionTime')"
                                :name="sortDirOf('nextExecutionTime') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__sortable"
                            :class="{ 'is-active': sortDirOf('status') }"
                            style="width: 130px;"
                            @click="toggleSort('status')"
                        >
                            {{ $t('frosh-tools.status') }}
                            <ft-icon
                                v-if="sortDirOf('status')"
                                :name="sortDirOf('status') === 'ASC' ? 'chevron-up' : 'chevron-down'"
                            />
                        </th>
                        <th
                            class="ft-table__actions"
                            style="width: 60px;"
                        ></th>
                    </tr>
                </thead>
                <tbody>
                    <tr
                        v-for="item in sortRows(items)"
                        :key="item.id"
                    >
                        <td>
                            <div class="ft-table__name">
                                {{ shortName(item.name) }}
                                <div class="ft-table__name-sub">{{ item.name }}</div>
                            </div>
                        </td>
                        <td class="ft-table__num">{{ item.runInterval }}s</td>
                        <td class="ft-mono">
                            {{ formatDate(item.lastExecutionTime) }}
                        </td>
                        <td class="ft-mono">
                            {{ formatDate(item.nextExecutionTime) }}
                        </td>
                        <td>
                            <ft-pill :variant="statusVariant(item.status)">{{ item.status }}</ft-pill>
                        </td>
                        <td class="ft-table__actions">
                            <div class="frosh-tab-scheduled__menu-wrap">
                                <button
                                    class="ft-btn ft-btn--ghost ft-btn--icon"
                                    @click.stop="toggleMenu(item.id)"
                                    :aria-expanded="openMenuId === item.id"
                                    aria-haspopup="true"
                                >
                                    <ft-icon name="more"/>
                                </button>
                                <div
                                    v-if="openMenuId === item.id"
                                    class="frosh-tab-scheduled__menu"
                                    @click.stop
                                >
                                    <button
                                        class="frosh-tab-scheduled__menu-item"
                                        @click="onMenu('edit', item)"
                                    >
                                        <ft-icon name="pencil"/>
                                        Edit interval &amp; next run
                                    </button>
                                    <button
                                        class="frosh-tab-scheduled__menu-item"
                                        @click="onMenu('run', item)"
                                    >
                                        <ft-icon name="play"/>
                                        {{ $t('frosh-tools.runManually') }}
                                    </button>
                                    <div class="frosh-tab-scheduled__menu-sep"></div>
                                    <button
                                        class="frosh-tab-scheduled__menu-item"
                                        @click="onMenu('schedule', item)"
                                    >
                                        {{ $t('frosh-tools.setToScheduled') }}
                                    </button>
                                    <button
                                        class="frosh-tab-scheduled__menu-item"
                                        @click="onMenu('schedule-immediate', item)"
                                    >
                                        {{ $t('frosh-tools.setToScheduledImmediately') }}
                                    </button>
                                    <div class="frosh-tab-scheduled__menu-sep"></div>
                                    <button
                                        class="frosh-tab-scheduled__menu-item frosh-tab-scheduled__menu-item--danger"
                                        @click="onMenu('deactivate', item)"
                                    >
                                        {{ $t('frosh-tools.setToInactive') }}
                                    </button>
                                </div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </ft-panel>
    <ft-modal
        v-if="editTask"
        :title="`Edit: ${shortName(editTask.name)}`"
        variant="small"
        @close="closeEdit"
    >
        <div class="frosh-tab-scheduled__edit">
            <sw-number-field
                v-model:value="editForm.runInterval"
                :label="$t('frosh-tools.interval') + ' (seconds)'"
                :min="1"
                numberType="int"
            />
            <sw-datepicker
                v-model:value="editForm.nextExecutionTime"
                :label="$t('frosh-tools.nextExecutionTime')"
                dateType="datetime"
            />
        </div>
        <template #footer>
            <button
                class="ft-btn"
                @click="closeEdit"
                :disabled="isSaving"
            >
                {{ $t('global.default.cancel') }}
            </button>
            <button
                class="ft-btn ft-btn--primary"
                @click="saveEdit"
                :disabled="isSaving"
            >
                <span
                    v-if="isSaving"
                    class="ft-spinner"
                ></span>
                <span>Save</span>
            </button>
        </template>
    </ft-modal>
    <ft-modal
        v-if="taskError"
        :title="$t('global.default.error')"
        @close="taskError = null"
    >
        <pre
            v-if="typeof taskError === 'object'"
            class="ft-diff"
            v-text="taskError"
        />
        <div
            v-else
            v-html="taskError"
        />
        <template #footer>
            <button
                class="ft-btn"
                @click="taskError = null"
            >
                {{ $t('global.default.close') }}
            </button>
        </template>
    </ft-modal>
</div>