<teleport to="body">
    <div
        class="ft ft-modal"
        @mousedown.self="onBackdrop"
    >
        <div
            ref="dialog"
            class="ft-modal__dialog"
            :class="`ft-modal__dialog--${variant}`"
            role="dialog"
            aria-modal="true"
            :aria-labelledby="title ? titleId : null"
            tabindex="-1"
        >
            <header
                class="ft-modal__head"
                v-if="$slots.header || title"
            >
                <slot name="header">
                    <h2
                        class="ft-modal__title"
                        :id="titleId"
                    >{{ title }}</h2>
                </slot>
                <button
                    class="ft-modal__close"
                    @click="close"
                    :aria-label="$t('global.default.close')"
                >
                    <ft-icon name="close"/>
                </button>
            </header>
            <div class="ft-modal__body">
                <slot/>
            </div>
            <footer
                class="ft-modal__foot"
                v-if="$slots.footer"
            >
                <slot name="footer"/>
            </footer>
        </div>
    </div>
</teleport>