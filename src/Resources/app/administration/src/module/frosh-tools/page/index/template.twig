<sw-page class="frosh-tools">
    <template
        #search-bar
        v-if="searchTab"
    >
        <sw-search-bar
            :key="$route.name"
            :initial-search-type="searchTab.type"
            :placeholder="$t(searchTab.placeholderKey)"
            :type-search-always-in-container="false"
            @search="onSearch"
        />
    </template>

    <template #content>
        <div class="ft ft-shell">
            <aside class="ft-sidebar">
                <div class="ft-sidebar__brand">
                    <div class="ft-sidebar__brand-mark">FT</div>
                    <div>
                        <div class="ft-sidebar__brand-title">{{ $t('frosh-tools.title') }}</div>
                        <div class="ft-sidebar__brand-sub">
                            {{ $t('frosh-tools.sidebar.developerConsole') }}
                        </div>
                    </div>
                </div>

                <button
                    type="button"
                    class="ft-sidebar__command"
                    @click="openCommandPalette"
                >
                    <ft-icon
                        name="search"
                        :size="14"
                    />
                    <span class="ft-sidebar__command-label">
                        {{ $t('frosh-tools.commandPalette.trigger') }}
                    </span>
                    <kbd class="ft-sidebar__command-kbd">{{ commandPaletteShortcut }}</kbd>
                </button>

                <template
                    v-for="group in navGroups"
                    :key="group.labelKey"
                >
                    <div
                        class="ft-sidebar__group"
                        v-if="group.items.length"
                    >
                        <div class="ft-sidebar__group-label">{{ $t(group.labelKey) }}</div>
                        <router-link
                            v-for="item in group.items"
                            :key="item.route"
                            :to="{ name: item.route }"
                            class="ft-sidebar__item"
                            active-class="is-active"
                        >
                            <span class="ft-sidebar__item-dot"></span>
                            <span>{{ $t(item.labelKey) }}</span>
                        </router-link>
                    </div>
                </template>
            </aside>
            <main class="ft-main">
                <router-view></router-view>
            </main>

            <ft-command-palette
                v-if="commandPaletteOpen"
                :elasticsearch-available="elasticsearchAvailable"
                :logs-available="logsAvailable"
                :fastly-available="fastlyAvailable"
                @close="closeCommandPalette"
            />
        </div>
    </template>
</sw-page>